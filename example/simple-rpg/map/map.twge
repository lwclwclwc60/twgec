def 地圖::生成地圖配置(x, y, object) : actions {
    // '---' 用作padding
    if(object == "---" || object == " . ") {}
    // 生成Sign (SP - Point, SW - Weapon, SS - Skill)
    else if(object == "SP0") {
        新增地圖物件(x = x, y = y, object = "石椅");
        新增告示牌(x = x, y = y, rotation = 180, text = "【重置能力點分配】", buttons = [Button(id = "ResetPoint", text = "確認")]);
    } else if(object == "SW1") {
        新增地圖物件(x = x, y = y, object = "小箱子");
        新增告示牌(x = x, y = y, rotation = 90, text = 文字::風杖描述, buttons = [Button(id = "wearWindStaff", text = "裝備"), Button(id = "wearNone", text = "卸下")]);
    } else if(object == "SW2") {
        新增地圖物件(x = x, y = y, object = "小箱子");
        新增告示牌(x = x, y = y, rotation = 90, text = 文字::匕首描述, buttons = [Button(id = "wearDagger", text = "裝備"), Button(id = "wearNone", text = "卸下")]);
    } else if(object == "SW3") {
        新增地圖物件(x = x, y = y, object = "小箱子");
        新增告示牌(x = x, y = y, rotation = 90, text = 文字::鐵劍描述, buttons = [Button(id = "wearIronSword", text = "裝備"), Button(id = "wearNone", text = "卸下")]);
    } else if(object == "SS1") {
        新增地圖物件(x = x, y = y, object = "小箱子");
        新增告示牌(x = x, y = y, rotation = 180, text = 文字::火星領域描述, buttons = [
            Button(id = "setX" + 別名::技能火星領域EN, text = "設置於X鍵"), 
            Button(id = "setXNone", text = "卸下")]);
    } else if(object == "SS2") {
        新增地圖物件(x = x, y = y, object = "小箱子");
        新增告示牌(x = x, y = y, rotation = 180, text = 文字::震撼描述, buttons = [
            Button(id = "setX" + 別名::技能震撼EN, text = "設置於X鍵"), 
            Button(id = "setXNone", text = "卸下")]);
    } else if(object == "SS3") {
        新增地圖物件(x = x, y = y, object = "小箱子");
        新增告示牌(x = x, y = y, rotation = 180, text = 文字::土靈召喚, buttons = [
            Button(id = "setX" + 別名::技能土靈召喚EN, text = "設置於X鍵"), 
            Button(id = "setXNone", text = "卸下")]);
    // 生成Device (DM - 魔法陣)
    } else if(object == "DM0") {
        新增回氣魔法陣(x = x, y = y, heal = "10", healActorCooldown = "4000", healDeviceCooldown = "1000");
    }
    // 生成NPC
    else if(object == "NP1") {
        新增角色(name = "武器商人", id = "npc01*", camp = "第三", x = x, y = y, rotation = 90,
                weapon1 = "fist", weapon2 = "fist", teamId = 100, role = "隱居士");
    } else if(object == "NP2") {
        新增角色(name = "技能商人", id = "npc02*", camp = "第三", x = x, y = y, rotation = 180,
                weapon1 = "fist", weapon2 = "fist", teamId = 100, role = "赤焰精靈");
    } else if(object == "NP3") {
        新增角色(name = "祭司", id = "npc03*", camp = "第三", x = x, y = y, rotation = 270,
                weapon1 = "fist", weapon2 = "fist", teamId = 100, role = "男靈能訓練官");
    } else if(object == "NP4") {
        新增角色(name = "村長", id = "npc04*", camp = "第三", x = x, y = y, rotation = 0,
                weapon1 = "fist", weapon2 = "fist", teamId = 100, externRole = "TWilightGameEventCompiler.character_village_head");
    }
    // 生成地圖物件
    else if(object == "LBx") {
        新增地圖物件(x = x, y = y, object = "大箱子", walkable = false);
    } else if(object == "SBx") {
        新增地圖物件(x = x, y = y, object = "小箱子", walkable = false);
    } else if(object == "H00") {
        新增地圖物件(x = x, y = y, object = "5x4橫向房子", walkable = false);
    } else if(object == "H01") {
        新增地圖物件(x = x, y = y, object = "5x4縱向房子", walkable = false);
    } else if(object == "***") {
        新增地圖物件(x = x, y = y, object = "草地");
    } else if(object == "t00") {
        新增地圖物件(x = x, y = y, object = "3x3綠樹");
    } else if(object == "r00") {
        新增地圖物件(x = x, y = y, object = "3x3黑石");
    } else if(object == "r01") {
        新增地圖物件(x = x, y = y, object = "3x3金石");
    } else if(object == "r02") {
        新增地圖物件(x = x, y = y, object = "2x2白石");
    } else if(object == "r03") {
        新增地圖物件(x = x, y = y, object = "1x1黑石");
    } else if(object == "r04") {
        新增地圖物件(x = x, y = y, object = "1x1金石");
    } else if(object == "r05") {
        新增地圖物件(x = x, y = y, object = "2x2棕石");
    // 生成出口
    } else if(object == "ExN") {
        新增地圖物件(x = x, y = y, object = "白光(上)");
    } else if(object == "ExE") {
        新增地圖物件(x = x, y = y, object = "白光(右)");
    } else if(object == "ExS") {
        新增地圖物件(x = x, y = y, object = "白光(下)");
    } else if(object == "ExW") {
        新增地圖物件(x = x, y = y, object = "白光(左)");
    } else {
        twge::assert(false, "無效地圖物件: " + object);
    }
}

def 地圖::生成地圖(xOffset, yOffset, mapArray) : actions {
    print(text = "xOffset:" + xOffset);
    print(text = "yOffset:" + yOffset);
    for(map_row in 0...(twge::get_length(mapArray) - 1)) {
        for(map_col in 0...(twge::get_length(twge::get_index(mapArray, map_row))/3 - 1)) {
            地圖::生成地圖配置(
                twge::to_string(map_col) + "+" + xOffset, twge::to_string(map_row) + "+" + yOffset,
                twge::get_slice(twge::get_index(mapArray, map_row), map_col*3 + 0, map_col*3 + 2)
            );
        }
    }
}

def 地圖::儲存地圖變量(x, y, map) : actions {
    if(twge::get_slice(twge::get_index(map,0),27,32) == "ExNExN") {
        儲存全域變數(key = "map_" + twge::to_string(x) + "_" + twge::to_string(y) + "_ExN", type = "int", value = 1);
    }
    if(twge::get_slice(twge::get_index(map,19),27,32) == "ExSExS"){
        儲存全域變數(key = "map_" + twge::to_string(x) + "_" + twge::to_string(y) + "_ExS", type = "int", value = 1);
    }
    if(twge::get_slice(twge::get_index(map,9),0,2) == "ExW" &&
       twge::get_slice(twge::get_index(map,10),0,2) == "ExW") {
        儲存全域變數(key = "map_" + twge::to_string(x) + "_" + twge::to_string(y) + "_ExW", type = "int", value = 1);
    }
    if(twge::get_slice(twge::get_index(map,9),57,59) == "ExE" &&
       twge::get_slice(twge::get_index(map,10),57,59) == "ExE") {
        儲存全域變數(key = "map_" + twge::to_string(x) + "_" + twge::to_string(y) + "_ExE", type = "int", value = 1);
    }
    儲存全域變數(key = "map_used_" + twge::to_string(x) + "_" + twge::to_string(y), type = "int", value = 0);
}


def 地圖::移動生成泛型(map_x, map_y) : block {
    __repeat__ = -1;
    __label__ = "地圖";
    checks {
        找出所有角色(actor = 角色::任何玩家, varname = "instance");
        角色所在區域(actorId = "instance", region_h = 1, region_w = 1, region_x = 23, region_y = 23);
        比較數字(lhs = "{map_used_{instance.map_x}_{instance.map_y}}", op = "==", rhs = "0");
        比較數字(lhs = "{instance.map_x}", op = "==", rhs = map_x);
        比較數字(lhs = "{instance.map_y}", op = "==", rhs = map_y);
        比較數字(lhs = "{chunk_available_stack_0}", op = "!=", rhs = -1);
        比較數字(lhs = "{chunk_available_stack_now}", op = "==", rhs = -1);
    }
    actions {
        儲存全域變數(key = "chunk_available_stack_now", type = "int", value = "{chunk_available_stack_0}");
        儲存全域變數(key = "chunk_available_stack_0", type = "int", value = "{chunk_available_stack_1}");
        儲存全域變數(key = "chunk_available_stack_1", type = "int", value = "{chunk_available_stack_2}");
        儲存全域變數(key = "chunk_available_stack_2", type = "int", value = "{chunk_available_stack_3}");
        儲存全域變數(key = "chunk_available_stack_3", type = "int", value = "{chunk_available_stack_4}");
        儲存全域變數(key = "chunk_available_stack_4", type = "int", value = "{chunk_available_stack_5}");
        儲存全域變數(key = "chunk_available_stack_5", type = "int", value = "{chunk_available_stack_6}");
        儲存全域變數(key = "chunk_available_stack_6", type = "int", value = "{chunk_available_stack_7}");
        儲存全域變數(key = "chunk_available_stack_7", type = "int", value = "{chunk_available_stack_8}");
        儲存全域變數(key = "chunk_available_stack_8", type = "int", value = -1);
        儲存全域變數(key = "map_to_chunk_{instance.map_x}_{instance.map_y}", type = "int", value = "{chunk_available_stack_now}");
        if(map_x == 99 && map_y == 100) {
            地圖::生成地圖("{chunk_{chunk_available_stack_now}_x}", "{chunk_{chunk_available_stack_now}_y}", 地圖::新手村近郊099n100);
        } else if(map_x == 101 && map_y == 100) {
            地圖::生成地圖("{chunk_{chunk_available_stack_now}_x}", "{chunk_{chunk_available_stack_now}_y}", 地圖::新手村近郊101n100);
        } else if(map_x == 99 && map_y == 101) {
            地圖::生成地圖("{chunk_{chunk_available_stack_now}_x}", "{chunk_{chunk_available_stack_now}_y}", 地圖::新手村近郊099n101);
        } else if(map_x == 100 && map_y == 101) {
            地圖::生成地圖("{chunk_{chunk_available_stack_now}_x}", "{chunk_{chunk_available_stack_now}_y}",  地圖::新手村近郊100n101);
        } else if(map_x == 101 && map_y == 101) {
            地圖::生成地圖("{chunk_{chunk_available_stack_now}_x}", "{chunk_{chunk_available_stack_now}_y}",  地圖::新手村近郊101n101);
        } else if(map_x == 99 && map_y == 102) {
            地圖::生成地圖("{chunk_{chunk_available_stack_now}_x}", "{chunk_{chunk_available_stack_now}_y}", 地圖::新手村近郊099n102);
        } else if(map_x == 100 && map_y == 102) {
            地圖::生成地圖("{chunk_{chunk_available_stack_now}_x}", "{chunk_{chunk_available_stack_now}_y}",  地圖::新手村近郊100n102);
        } else if(map_x == 101 && map_y == 102) {
            地圖::生成地圖("{chunk_{chunk_available_stack_now}_x}", "{chunk_{chunk_available_stack_now}_y}",  地圖::新手村近郊101n102);
        }
        儲存全域變數(key = "chunk_to_map_{chunk_available_stack_now}_x", type = "int", value = "{instance.map_x}");
        儲存全域變數(key = "chunk_to_map_{chunk_available_stack_now}_y", type = "int", value = "{instance.map_y}");
        儲存全域變數(key = "map_used_{instance.map_x}_{instance.map_y}", type = "int", value = 1);
        儲存全域變數(key = "chunk_entering_{chunk_available_stack_now}", type = "int", value = 1);
        儲存全域變數(key = "chunk_used_{chunk_available_stack_now}", type = "int", value = 1);
        儲存全域變數(key = "chunk_available_stack_now", type = "int", value = -1);
    }
}

block 移動生成099_100 = 地圖::移動生成泛型(99,100);
block 移動生成101_100 = 地圖::移動生成泛型(101,100);
block 移動生成099_101 = 地圖::移動生成泛型(99,101);
block 移動生成100_101 = 地圖::移動生成泛型(100,101);
block 移動生成101_101 = 地圖::移動生成泛型(101,101);
block 移動生成099_102 = 地圖::移動生成泛型(99,102);
block 移動生成100_102 = 地圖::移動生成泛型(100,102);
block 移動生成101_102 = 地圖::移動生成泛型(101,102);

block 地圖初始化 {
    __label__ = "地圖";
    actions {
        /*
        chunk的x grid座標: const int -> chunk_{chunk_id}_x
        chunk的y grid座標: const int -> chunk_{chunk_id}_y
        chunk到map_x的映射: int -> chunk_to_map_x_{chunk_id}
        chunk到map_y的映射: int -> chunk_to_map_y_{chunk_id}
        chunk使用狀態: [0,1] -> chunk_used_{chunk_id}
        空閒chunk的stack: [1,8] -> chunk_available_stack_{stack_id}

        map可往東走: const [0,1] -> map_{map_x}_{map_y}_ExE
        map可往南走: const [0,1] -> map_{map_x}_{map_y}_ExS
        map可往西走: const [0,1] -> map_{map_x}_{map_y}_ExW
        map可往北走: const [0,1] -> map_{map_x}_{map_y}_ExN
        map到chunk的映射: int -> map_to_chunk_{map_x}_{map_y}
        map使用狀態: [0,1] -> map_used_{map_x}_{map_y}

        角色所在map: int -> instnace.map_x
        角色所在map: int -> instnace.map_y
        角色移動方向: [東,南,西,北] -> instance.map_direction
        */
        儲存全域變數(key = "chunk_0_x", type = "int", value = 0);
        儲存全域變數(key = "chunk_0_y", type = "int", value = 0);
        儲存全域變數(key = "chunk_1_x", type = "int", value = 27);
        儲存全域變數(key = "chunk_1_y", type = "int", value = 0);
        儲存全域變數(key = "chunk_2_x", type = "int", value = 54);
        儲存全域變數(key = "chunk_2_y", type = "int", value = 0);
        儲存全域變數(key = "chunk_3_x", type = "int", value = 0);
        儲存全域變數(key = "chunk_3_y", type = "int", value = 27);
        儲存全域變數(key = "chunk_4_x", type = "int", value = 27);
        儲存全域變數(key = "chunk_4_y", type = "int", value = 27);
        儲存全域變數(key = "chunk_5_x", type = "int", value = 54);
        儲存全域變數(key = "chunk_5_y", type = "int", value = 27);
        儲存全域變數(key = "chunk_6_x", type = "int", value = 0);
        儲存全域變數(key = "chunk_6_y", type = "int", value = 54);
        儲存全域變數(key = "chunk_7_x", type = "int", value = 27);
        儲存全域變數(key = "chunk_7_y", type = "int", value = 54);
        儲存全域變數(key = "chunk_8_x", type = "int", value = 54);
        儲存全域變數(key = "chunk_8_y", type = "int", value = 54);
        儲存全域變數(key = "chunk_used_0", type = "int", value = 1);
        儲存全域變數(key = "chunk_used_1", type = "int", value = 0);
        儲存全域變數(key = "chunk_used_2", type = "int", value = 0);
        儲存全域變數(key = "chunk_used_3", type = "int", value = 0);
        儲存全域變數(key = "chunk_used_4", type = "int", value = 0);
        儲存全域變數(key = "chunk_used_5", type = "int", value = 0);
        儲存全域變數(key = "chunk_used_6", type = "int", value = 0);
        儲存全域變數(key = "chunk_used_7", type = "int", value = 0);
        儲存全域變數(key = "chunk_used_8", type = "int", value = 0);
        儲存全域變數(key = "chunk_entering_1", type = "int", value = 0);
        儲存全域變數(key = "chunk_entering_2", type = "int", value = 0);
        儲存全域變數(key = "chunk_entering_3", type = "int", value = 0);
        儲存全域變數(key = "chunk_entering_4", type = "int", value = 0);
        儲存全域變數(key = "chunk_entering_5", type = "int", value = 0);
        儲存全域變數(key = "chunk_entering_6", type = "int", value = 0);
        儲存全域變數(key = "chunk_entering_7", type = "int", value = 0);
        儲存全域變數(key = "chunk_entering_8", type = "int", value = 0);
        儲存全域變數(key = "chunk_available_stack_now", type = "int", value = -1);
        儲存全域變數(key = "chunk_available_stack_0", type = "int", value = 1);
        儲存全域變數(key = "chunk_available_stack_1", type = "int", value = 2);
        儲存全域變數(key = "chunk_available_stack_2", type = "int", value = 3);
        儲存全域變數(key = "chunk_available_stack_3", type = "int", value = 4);
        儲存全域變數(key = "chunk_available_stack_4", type = "int", value = 5);
        儲存全域變數(key = "chunk_available_stack_5", type = "int", value = 6);
        儲存全域變數(key = "chunk_available_stack_6", type = "int", value = 7);
        儲存全域變數(key = "chunk_available_stack_7", type = "int", value = 8);
        儲存全域變數(key = "chunk_available_stack_8", type = "int", value = -1);
        地圖::儲存地圖變量(099, 100, 地圖::新手村近郊099n100);
        地圖::儲存地圖變量(100, 100, 地圖::新手村100n100);
        地圖::儲存地圖變量(101, 100, 地圖::新手村近郊101n100);
        地圖::儲存地圖變量(099, 101, 地圖::新手村近郊099n101);
        地圖::儲存地圖變量(100, 101, 地圖::新手村近郊100n101);
        地圖::儲存地圖變量(101, 101, 地圖::新手村近郊101n101);
        地圖::儲存地圖變量(099, 102, 地圖::新手村近郊099n102);
        地圖::儲存地圖變量(100, 102, 地圖::新手村近郊100n102);
        地圖::儲存地圖變量(101, 102, 地圖::新手村近郊101n102);
        // 特化(100,100)新手村地圖
        儲存全域變數(key = "chunk_to_map_0_x", type = "int", value = 100);
        儲存全域變數(key = "chunk_to_map_0_y", type = "int", value = 100);
        儲存全域變數(key = "map_to_chunk_100_100", type = "int", value = 0);
        儲存全域變數(key = "map_used_100_100", type = "int", value = 1);
        地圖::生成地圖("{chunk_{map_to_chunk_100_100}_x}", "{chunk_{map_to_chunk_100_100}_y}", 地圖::新手村100n100);
    }
}