    __repeat__ = -1;
    __label__ = "地圖";
    checks {
        比較數字(lhs = "{chunk_available_stack_0}", op = "==", rhs = -1);
        比較數字(lhs = "{chunk_available_stack_1}+{chunk_available_stack_2}+{chunk_available_stack_3}+{chunk_available_stack_4}+{chunk_available_stack_5}+{chunk_available_stack_6}+{chunk_available_stack_7}+{chunk_available_stack_8}", op = "!=", rhs = -8);
