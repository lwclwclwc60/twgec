block 拾取經驗一級鹿 {
    __repeat__ = -1;
    __label__ = "怪物";
    triggers {
        拾取武器道具(actorVarname = "instance", matchKind = "equal", itemMatchCode = "deer_exp_01");
    }
    actions {
        儲存物件變數(key = "Exp", object = "instance", type = "integer", value = ("{instance.Exp}+" + twge::to_string(1)));
        地圖標示文字(x = 公式::InstanceX坐標, y = 公式::InstanceY坐標, html = true, text = ("<span style='color: green'>EXP+" + (twge::to_string(1) + "</span>")));
        儲存玩家狀態(category = 狀態讀寫密鑰, key = "Point", playerId = "{instance}", type = "string", value = ("{{instance}." + ("Point" + "}")));
        儲存玩家狀態(category = 狀態讀寫密鑰, key = "ExpNeeded", playerId = "{instance}", type = "string", value = ("{{instance}." + ("ExpNeeded" + "}")));
        儲存玩家狀態(category = 狀態讀寫密鑰, key = "Level", playerId = "{instance}", type = "string", value = ("{{instance}." + ("Level" + "}")));
        儲存玩家狀態(category = 狀態讀寫密鑰, key = "STR", playerId = "{instance}", type = "string", value = ("{{instance}." + ("STR" + "}")));
