    }
    actions {
        面板::顯示能力面板();
    }
}
block 點擊能力分配一點力量 {
    __repeat__ = -1;
    __label__ = "面板";
    triggers {
        視窗確認(buttonName = ("dialog_button_point_" + ("STR" + ("_" + "01"))), playerLocalId = "instance");
    }
    checks {
        比較數字(lhs = "{instance.Point}", op = ">=", rhs = "01");
    }
    actions {
        關閉彈出視窗(actorId = "{instance}", dialogId = "dialog_point");
        自定義::儲存Instance整數(key = "Point", value = ("{instance.Point} - " + "01"));
        自定義::儲存Instance整數(key = "STR", value = ("{instance." + ("STR" + ("} + " + "01"))));
        自定義::更新角色屬性(actorId = "instance");
        自定義::上載Instance數據();
        面板::顯示能力面板();
    }
}
