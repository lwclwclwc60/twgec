            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = "<=", rhs = "11*32");
            比較數字(lhs = "{map_{{clicker.id}.map_x}_{{clicker.id}.map_y}_ExE}", op = "==", rhs = 1);
        }
    }
    actions {
        setGlobal(key = "instance", type = "string", value = "{clicker.id}");
        儲存物件變數(key = "tmp_grid_x_offset", object = "instance", type = "integer", value = "({instance.gamePosition.x}%864)/32");
        儲存物件變數(key = "tmp_grid_y_offset", object = "instance", type = "integer", value = "({instance.gamePosition.y}%864)/32");
        if(false) {
            print(text = "x: {instance.map_x}, y: {instance.map_y}, direction: 右", type = "error");
            print(text = "x_offset: {instance.tmp_grid_x_offset}, y_offset: {instance.tmp_grid_x_offset}", type = "error");
        }
        儲存物件變數(key = "map_direction", object = "instance", type = "string", value = "右");
        if(true) {
            儲存物件變數(key = "map_x", object = "instance", type = "integer", value = "{instance.map_x}+1");
        }
        移動角色位置(actorId = "instance", x = 23, y = 23);
    }
}
