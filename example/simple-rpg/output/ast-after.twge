        自定義::儲存Instance整數(key = "map_y", value = 100);
    }
    checks {
    }
}
block 玩家初始化 {
    __repeat__ = -1;
    __label__ = "玩家";
    triggers {
        角色進入戰場(actor = 角色::任何玩家, varName = "instance");
    }
    actions {
        自定義::儲存Instance整數(key = "STR", value = 0);
        自定義::儲存Instance整數(key = "CON", value = 0);
        自定義::儲存Instance整數(key = "AGI", value = 0);
        自定義::儲存Instance整數(key = "INT", value = 0);
        自定義::儲存Instance整數(key = "PSY", value = 0);
        自定義::儲存Instance整數(key = "Level", value = 1);
        自定義::儲存Instance整數(key = "Point", value = 5);
        自定義::儲存Instance整數(key = "Exp", value = 0);
        自定義::儲存Instance整數(key = "ExpNeeded", value = 6);
        自定義::儲存Instance整數(key = "HP", value = 100);
        自定義::儲存Instance整數(key = "map_x", value = 100);
        自定義::儲存Instance整數(key = "map_y", value = 100);
        儲存物件變數(key = "XSkill", object = "instance", type = "string", value = "無");
        取得玩家狀態(category = 狀態讀寫密鑰, key = "savedBefore", playerId = "{instance}", varName = "{instance}_savedBefore");
        人物裝備武器(actorCode = "instance", type = "fist", hand = 1);
        人物裝備武器(actorCode = "instance", type = "fist", hand = 2);
        角色說話(actorId = "instance", cleanTalk = true, text = "玩家初始中");
        設定角色屬性(actorId = "instance", attr = "group", value = "100");
        等待(duration = 500);
        自定義::儲存Instance整數(key = "completedInit", value = 1);
        for(x in 0...2) {
            for(y in 0...2) {
                角色重生位置(actorId = "{instance}", x = (x * 27), y = (y * 27));
            }
        }
        角色重生位置(actorId = "{instance}", x = 23, y = 23);
        角色重生位置(actorId = "{instance}", x = 10, y = 10);
    }
    checks {
    }
}
block 遊戲初始化 {
    actions {
        迴避友軍攻擊();
    }
    checks {
    }
    triggers {
    }
}
//--------------------------------//
//--- AST After functionInling ---//
//--------------------------------//
const 公式::Instance角度 = "{instance.bodyRotation}*180/3.14";
const 公式::Instance血量 = "98 + 10*{instance.CON} + 2*{instance.Level}";
const 公式::Instance恢復量 = "1 + {instance.PSY} + {instance.CON}/2";
const 公式::InstanceX坐標 = "{instance.gamePosition.x}/32";
const 公式::InstanceY坐標 = "{instance.gamePosition.y}/32";
const 文字::HTML等級提升 = "<span style='color: green'>Level Up</span>";
const 角色::任何 = ActorMatch();
const 角色::任何玩家 = ActorMatch(controller = "player");
const 角色::任何電腦 = ActorMatch(controller = "ai");
const 角色::任何友軍 = ActorMatch(group = 100);
const 角色::任何敵軍 = ActorMatch(group = 101);
const 出生點 = Point(10,10);
const 除錯模式 = false;
const 狀態讀寫密鑰 = "simple-rpg-test";
const 公式::風杖物理傷害 = "5+{attacker.STR}/2";
const 公式::風杖光彈傷害 = "{instance.INT} + {instance.PSY}/2 + 10";
const 公式::鐵劍物理傷害 = "30+{attacker.STR}*3";
const 公式::鐵劍技能恢復 = "1 + {instance.STR}/6 + {instance.CON}/3";
const 公式::鐵劍技能傷害 = "1 + {instance.STR}/3 + {instance.CON}/6";
const 公式::匕首物理傷害 = "10+{attacker.STR}*2+{attacker.AGI}";
const 公式::匕首技能傷害 = "10 + {instance.AGI}*2";
const 文字::風杖描述 = ("【風杖】\n" + ("【普通攻擊】\n" + (" - 武器傷害: 5+力量÷2\n" + (" - 光彈傷害: 10+智慧+精神÷2\n" + ("【技能】散射釋出五發光彈\n" + " - 光彈傷害: 10+智慧+精神÷2")))));
const 文字::鐵劍描述 = ("【鐵劍】\n" + ("【普通攻擊】\n" + (" - 武器傷害: 30+力量×3\n" + ("【技能】對範圍内的角色造成十次傷害及治療\n" + (" - 對敵軍傷害量: 1+力量÷3+體質÷6\n" + " - 對友軍回復量: 1+力量÷6+體質÷3")))));
const 文字::匕首描述 = ("【匕首】\n" + ("【普通攻擊】\n" + (" - 武器傷害: 10+力量×2+敏捷\n" + ("【技能】移動至滑鼠指定位置，並在目的範圍內造成傷害\n" + " - 範圍傷害：10+敏捷×2"))));
const 別名::武器風杖 = "custom_wind_staff";
const 別名::武器鐵劍 = "custom_iron_sword";
const 別名::武器匕首 = "custom_dagger";
const 公式::火星領域傷害 = "{instance.INT}/4+{instance.PSY}/6";
const 公式::震撼傷害 = "1+{instance.CON}/3";
const 公式::震撼範圍 = "60+10*{instance.CON}^0.5";
const 公式::土靈召喚血量 = "100+{instance.PSY}*2";
const 公式::土靈召喚傷害 = "10+{instance.PSY}/5";
