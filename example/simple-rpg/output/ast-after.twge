block 點擊重置能力 {
    __repeat__ = -1;
    __label__ = "玩家";
    triggers {
        告示牌按鈕(varName = "instance", buttonId = "ResetPoint");
    }
    actions {
        儲存物件變數(key = "Point", object = "instance", type = "integer", value = "{instance.Level}*2+3");
        儲存物件變數(key = "STR", object = "instance", type = "integer", value = 0);
        儲存物件變數(key = "CON", object = "instance", type = "integer", value = 0);
        儲存物件變數(key = "AGI", object = "instance", type = "integer", value = 0);
        儲存物件變數(key = "INT", object = "instance", type = "integer", value = 0);
        儲存物件變數(key = "PSY", object = "instance", type = "integer", value = 0);
        角色說話(actorId = "instance", text = "成功重設能力點，目前有{instance.Point}點能力點");
        儲存物件變數(key = "HP", object = "instance", type = "integer", value = "98 + 10*{instance.CON} + 2*{instance.Level}");
        設定角色屬性(actorId = "instance", attr = "maxHp", value = "{instance.HP}");
        設定角色屬性(actorId = "instance", attr = "closeWeaponSpeed", value = "4-3/(1+0.01*{instance.AGI})");
        設定角色屬性(actorId = "instance", attr = "weight", value = "3*pow(0.97,{instance.AGI})");
        儲存玩家狀態(category = "simple-rpg-test", key = "Point", playerId = "{instance}", type = "string", value = "{{instance}.Point}");
        儲存玩家狀態(category = "simple-rpg-test", key = "ExpNeeded", playerId = "{instance}", type = "string", value = "{{instance}.ExpNeeded}");
