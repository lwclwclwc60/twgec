block 查看主面板 {
    __repeat__ = -1;
    __label__ = "面板";
    triggers {
        鍵盤按鍵(varName = "clicker", key = "Z");
    }
    actions {
        關閉彈出視窗(actorId = "{instance}", dialogId = "dialog_main");
        儲存全域變數(key = "instance", type = "string", value = "{clicker.id}");
        彈出選項視窗(actorId = "{instance}", dialogId = "dialog_main", message = "<div>【Lv{instance.Level}】</div><div>Exp:{instance.Exp}/{instance.ExpNeeded}</div><div>尚餘能力點：{instance.Point}</div><div>力量：{instance.STR}</div><div>體質：{instance.CON}</div><div>敏捷：{instance.AGI}</div><div>智慧：{instance.INT}</div><div>精神：{instance.PSY}\n</div><div>按鍵X技能: 【{instance.XSkill}】</div>", options = [Button(id = "dialog_button_point", text = "分配點數")]);
    }
    checks {
    }
}
block 查看能力面板 {
    __repeat__ = -1;
    __label__ = "面板";
    triggers {
        視窗確認(buttonName = "dialog_button_point", playerLocalId = "instance");
    }
    actions {
        彈出選項視窗(actorId = "{instance}", dialogId = "dialog_point", message = "<div>尚餘能力點：{instance.Point}</div><div>力量：{instance.STR}</div><div>每一點可提升若干的武器物理傷害，詳細見各武器描述</div><div>體質：{instance.CON}</div><div>每一點可提升半點恢復力，及增加十點血量上限</div><div>敏捷：{instance.AGI}</div><div>每一點可提升若干的匕首物理傷害，並降低重量及提升武器攻擊速度</div><div>智慧：{instance.INT}</div><div>每一點可提升若干的杖類傷害，詳細見各武器描述</div><div>精神：{instance.PSY}\n</div><div>每一點可提升一點恢復力，及提升小量的杖類傷害</div>", options = [Button(id = "dialog_button_point_STR_01", text = "分配一點力量"),Button(id = "dialog_button_point_STR_10", text = "分配十點力量"),Button(id = "dialog_button_point_CON_01", text = "分配一點體質"),Button(id = "dialog_button_point_CON_10", text = "分配十點體質"),Button(id = "dialog_button_point_AGI_01", text = "分配一點敏捷"),Button(id = "dialog_button_point_AGI_10", text = "分配十點敏捷"),Button(id = "dialog_button_point_INT_01", text = "分配一點智慧"),Button(id = "dialog_button_point_INT_10", text = "分配十點智慧"),Button(id = "dialog_button_point_PSY_01", text = "分配一點精神"),Button(id = "dialog_button_point_PSY_10", text = "分配十點精神")]);
    }
    checks {
    }
}
block 點擊能力分配一點力量 {
    __repeat__ = -1;
    __label__ = "面板";
    triggers {
        視窗確認(buttonName = "dialog_button_point_STR_01", playerLocalId = "instance");
    }
    checks {
        比較數字(lhs = "{instance.Point}", op = ">=", rhs = "01");
    }
    actions {
        關閉彈出視窗(actorId = "{instance}", dialogId = "dialog_point");
        儲存物件變數(key = "Point", object = "instance", type = "integer", value = "{instance.Point} - 01");
        儲存物件變數(key = "STR", object = "instance", type = "integer", value = "{instance.STR} + 01");
        儲存物件變數(key = "HP", object = "instance", type = "integer", value = "98 + 10*{instance.CON} + 2*{instance.Level}");
        設定角色屬性(actorId = "instance", attr = "maxHp", value = "{instance.HP}");
        設定角色屬性(actorId = "instance", attr = "closeWeaponSpeed", value = "4-3/(1+0.01*{instance.AGI})");
        設定角色屬性(actorId = "instance", attr = "weight", value = "3*pow(0.97,{instance.AGI})");
        儲存玩家狀態(category = "simple-rpg-test", key = "Point", playerId = "{instance}", type = "string", value = "{{instance}.Point}");
        儲存玩家狀態(category = "simple-rpg-test", key = "ExpNeeded", playerId = "{instance}", type = "string", value = "{{instance}.ExpNeeded}");
        儲存玩家狀態(category = "simple-rpg-test", key = "Level", playerId = "{instance}", type = "string", value = "{{instance}.Level}");
        儲存玩家狀態(category = "simple-rpg-test", key = "STR", playerId = "{instance}", type = "string", value = "{{instance}.STR}");
        儲存玩家狀態(category = "simple-rpg-test", key = "CON", playerId = "{instance}", type = "string", value = "{{instance}.CON}");
        儲存玩家狀態(category = "simple-rpg-test", key = "AGI", playerId = "{instance}", type = "string", value = "{{instance}.AGI}");
        儲存玩家狀態(category = "simple-rpg-test", key = "INT", playerId = "{instance}", type = "string", value = "{{instance}.INT}");
        儲存玩家狀態(category = "simple-rpg-test", key = "PSY", playerId = "{instance}", type = "string", value = "{{instance}.PSY}");
        儲存玩家狀態(category = "simple-rpg-test", key = "Exp", playerId = "{instance}", type = "string", value = "{{instance}.Exp}");
        儲存玩家狀態(category = "simple-rpg-test", key = "HP", playerId = "{instance}", type = "string", value = "{{instance}.HP}");
        儲存玩家狀態(category = "simple-rpg-test", key = "savedBefore", playerId = "{instance}", type = "integer", value = "1");
        彈出選項視窗(actorId = "{instance}", dialogId = "dialog_point", message = "<div>尚餘能力點：{instance.Point}</div><div>力量：{instance.STR}</div><div>每一點可提升若干的武器物理傷害，詳細見各武器描述</div><div>體質：{instance.CON}</div><div>每一點可提升半點恢復力，及增加十點血量上限</div><div>敏捷：{instance.AGI}</div><div>每一點可提升若干的匕首物理傷害，並降低重量及提升武器攻擊速度</div><div>智慧：{instance.INT}</div><div>每一點可提升若干的杖類傷害，詳細見各武器描述</div><div>精神：{instance.PSY}\n</div><div>每一點可提升一點恢復力，及提升小量的杖類傷害</div>", options = [Button(id = "dialog_button_point_STR_01", text = "分配一點力量"),Button(id = "dialog_button_point_STR_10", text = "分配十點力量"),Button(id = "dialog_button_point_CON_01", text = "分配一點體質"),Button(id = "dialog_button_point_CON_10", text = "分配十點體質"),Button(id = "dialog_button_point_AGI_01", text = "分配一點敏捷"),Button(id = "dialog_button_point_AGI_10", text = "分配十點敏捷"),Button(id = "dialog_button_point_INT_01", text = "分配一點智慧"),Button(id = "dialog_button_point_INT_10", text = "分配十點智慧"),Button(id = "dialog_button_point_PSY_01", text = "分配一點精神"),Button(id = "dialog_button_point_PSY_10", text = "分配十點精神")]);
