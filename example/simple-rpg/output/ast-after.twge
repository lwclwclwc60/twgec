__roomSize__ = 8;
block 下載老玩家數據 {
    __repeat__ = -1;
    __label__ = "玩家";
    checks {
        找出所有角色(actor = 角色::任何玩家, varname = "instance");
        比較數字(lhs = "{instance.completedInit}", op = "==", rhs = 1);
        if(true) {
            比對字串(str = "{{instance}_savedBefore}", matchKind = "equal", value = "1");
        } else {
            比對字串(str = "{{instance}_savedBefore}", matchKind = "equal", value = "undefined");
        }
    }
    actions {
        儲存物件變數(key = "completedInit", object = "instance", type = "string", value = 2);
        if(true) {
            取得玩家狀態(category = 狀態讀寫密鑰, key = "Point", playerId = "{instance}", varName = ("{instance}_" + "Point"));
            儲存物件變數(key = "Point", object = "instance", type = "integer", value = ("{{instance}_" + ("Point" + "}")));
            取得玩家狀態(category = 狀態讀寫密鑰, key = "ExpNeeded", playerId = "{instance}", varName = ("{instance}_" + "ExpNeeded"));
            儲存物件變數(key = "ExpNeeded", object = "instance", type = "integer", value = ("{{instance}_" + ("ExpNeeded" + "}")));
            取得玩家狀態(category = 狀態讀寫密鑰, key = "Level", playerId = "{instance}", varName = ("{instance}_" + "Level"));
            儲存物件變數(key = "Level", object = "instance", type = "integer", value = ("{{instance}_" + ("Level" + "}")));
            取得玩家狀態(category = 狀態讀寫密鑰, key = "STR", playerId = "{instance}", varName = ("{instance}_" + "STR"));
            儲存物件變數(key = "STR", object = "instance", type = "integer", value = ("{{instance}_" + ("STR" + "}")));
            取得玩家狀態(category = 狀態讀寫密鑰, key = "CON", playerId = "{instance}", varName = ("{instance}_" + "CON"));
            儲存物件變數(key = "CON", object = "instance", type = "integer", value = ("{{instance}_" + ("CON" + "}")));
            取得玩家狀態(category = 狀態讀寫密鑰, key = "AGI", playerId = "{instance}", varName = ("{instance}_" + "AGI"));
            儲存物件變數(key = "AGI", object = "instance", type = "integer", value = ("{{instance}_" + ("AGI" + "}")));
            取得玩家狀態(category = 狀態讀寫密鑰, key = "INT", playerId = "{instance}", varName = ("{instance}_" + "INT"));
            儲存物件變數(key = "INT", object = "instance", type = "integer", value = ("{{instance}_" + ("INT" + "}")));
            取得玩家狀態(category = 狀態讀寫密鑰, key = "PSY", playerId = "{instance}", varName = ("{instance}_" + "PSY"));
            儲存物件變數(key = "PSY", object = "instance", type = "integer", value = ("{{instance}_" + ("PSY" + "}")));
            取得玩家狀態(category = 狀態讀寫密鑰, key = "Exp", playerId = "{instance}", varName = ("{instance}_" + "Exp"));
            儲存物件變數(key = "Exp", object = "instance", type = "integer", value = ("{{instance}_" + ("Exp" + "}")));
            取得玩家狀態(category = 狀態讀寫密鑰, key = "HP", playerId = "{instance}", varName = ("{instance}_" + "HP"));
            儲存物件變數(key = "HP", object = "instance", type = "integer", value = ("{{instance}_" + ("HP" + "}")));
            儲存物件變數(key = "HP", object = "instance", type = "integer", value = ("98 + 10*{" + ("instance" + (".CON} + 2*{" + ("instance" + ".Level}")))));
            設定角色屬性(actorId = "instance", attr = "maxHp", value = ("{" + ("instance" + ".HP}")));
            設定角色屬性(actorId = "instance", attr = "closeWeaponSpeed", value = ("4-3/(1+0.01*{" + ("instance" + ".AGI})")));
            設定角色屬性(actorId = "instance", attr = "weight", value = ("3*pow(0.97,{" + ("instance" + ".AGI})")));
            角色加減血(actorCode = "instance", type = "heal", value = 9999);
        }
        角色說話(actorId = "instance", cleanTalk = true, text = "初始化完畢");
    }
    triggers {
    }
}
