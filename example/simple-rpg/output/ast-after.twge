        儲存玩家狀態(category = "simple-rpg-test", key = "savedBefore", playerId = "{instance}", type = "integer", value = "1");
        彈出選項視窗(actorId = "{instance}", dialogId = "dialog_point", message = "<div>尚餘能力點：{instance.Point}</div><div>力量：{instance.STR}</div><div>每一點可提升若干的武器物理傷害，詳細見各武器描述</div><div>體質：{instance.CON}</div><div>每一點可提升半點恢復力，及增加十點血量上限</div><div>敏捷：{instance.AGI}</div><div>每一點可提升若干的匕首物理傷害，並降低重量及提升武器攻擊速度</div><div>智慧：{instance.INT}</div><div>每一點可提升若干的杖類傷害，詳細見各武器描述</div><div>精神：{instance.PSY}\n</div><div>每一點可提升一點恢復力，及提升小量的杖類傷害</div>", options = [Button(id = "dialog_button_point_STR_01", text = "分配一點力量"),Button(id = "dialog_button_point_STR_10", text = "分配十點力量"),Button(id = "dialog_button_point_CON_01", text = "分配一點體質"),Button(id = "dialog_button_point_CON_10", text = "分配十點體質"),Button(id = "dialog_button_point_AGI_01", text = "分配一點敏捷"),Button(id = "dialog_button_point_AGI_10", text = "分配十點敏捷"),Button(id = "dialog_button_point_INT_01", text = "分配一點智慧"),Button(id = "dialog_button_point_INT_10", text = "分配十點智慧"),Button(id = "dialog_button_point_PSY_01", text = "分配一點精神"),Button(id = "dialog_button_point_PSY_10", text = "分配十點精神")]);
    }
}
block 點擊重置能力 {
    __repeat__ = -1;
