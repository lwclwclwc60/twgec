block 野獸重生x099y100鹿 {
    __repeat__ = -1;
    __repeatInterval__ = 8000;
    __delay__ = 1000;
    __label__ = "怪物";
    checks {
        if(("鹿" == "鹿")) {
            if((("99" == "101") && ("100" == "102"))) {
                計算人數(actor = ActorMatch(id = ("monster_deer_lv0" + twge::to_string(1)), matchKind = "contain"), op = "<", value = 2);
            } else {
                計算人數(actor = ActorMatch(id = ("monster_deer_lv0" + twge::to_string(1)), matchKind = "contain"), op = "<", value = 4);
            }
        }
        if(("鹿" == "山嶺石怪")) {
            計算人數(actor = ActorMatch(id = ("monster_stone_lv0" + twge::to_string(1)), matchKind = "contain"), op = "<", value = 1);
        }
        比較數字(lhs = ("{map_used_" + ("99" + ("_" + ("100" + "}")))), op = "==", rhs = "1");
    }
