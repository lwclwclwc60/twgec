def 地圖::生成地圖(xOffset, yOffset, mapArray) : actions {
    print(text = ("xOffset:" + xOffset));
    print(text = ("yOffset:" + yOffset));
    for(map_row in 0...(twge::get_length(mapArray) - 1)) {
        for(map_col in 0...((twge::get_length(twge::get_index(mapArray, map_row)) / 3) - 1)) {
            地圖::生成地圖配置((twge::to_string(map_col) + ("+" + xOffset)), (twge::to_string(map_row) + ("+" + yOffset)), twge::get_slice(twge::get_index(mapArray, map_row), ((map_col * 3) + 0), ((map_col * 3) + 2)));
        }
    }
}
def 地圖::儲存地圖變量(x, y, map) : actions {
    if((twge::get_slice(twge::get_index(map, 0), 27, 32) == "ExNExN")) {
        儲存全域變數(key = ("map_" + (twge::to_string(x) + ("_" + (twge::to_string(y) + "_ExN")))), type = "int", value = 1);
    }
    if((twge::get_slice(twge::get_index(map, 19), 27, 32) == "ExSExS")) {
        儲存全域變數(key = ("map_" + (twge::to_string(x) + ("_" + (twge::to_string(y) + "_ExS")))), type = "int", value = 1);
    }
    if(((twge::get_slice(twge::get_index(map, 9), 0, 2) == "ExW") && (twge::get_slice(twge::get_index(map, 10), 0, 2) == "ExW"))) {
        儲存全域變數(key = ("map_" + (twge::to_string(x) + ("_" + (twge::to_string(y) + "_ExW")))), type = "int", value = 1);
    }
    if(((twge::get_slice(twge::get_index(map, 9), 57, 59) == "ExE") && (twge::get_slice(twge::get_index(map, 10), 57, 59) == "ExE"))) {
        儲存全域變數(key = ("map_" + (twge::to_string(x) + ("_" + (twge::to_string(y) + "_ExE")))), type = "int", value = 1);
    }
    儲存全域變數(key = ("map_used_" + (twge::to_string(x) + ("_" + twge::to_string(y)))), type = "int", value = 0);
}
def 地圖::移動生成泛型(map_x, map_y) : block {
    __repeat__ = -1;
    __label__ = "地圖";
    checks {
        找出所有角色(actor = 角色::任何玩家, varname = "instance");
        角色所在區域(actorId = "instance", region_h = 1, region_w = 1, region_x = 23, region_y = 23);
        比較數字(lhs = "{map_used_{instance.map_x}_{instance.map_y}}", op = "==", rhs = "0");
        比較數字(lhs = "{instance.map_x}", op = "==", rhs = map_x);
        比較數字(lhs = "{instance.map_y}", op = "==", rhs = map_y);
        比較數字(lhs = "{chunk_available_stack_0}", op = "!=", rhs = -1);
        比較數字(lhs = "{chunk_available_stack_now}", op = "==", rhs = -1);
    }
    actions {
        儲存全域變數(key = "chunk_available_stack_now", type = "int", value = "{chunk_available_stack_0}");
        儲存全域變數(key = "chunk_available_stack_0", type = "int", value = "{chunk_available_stack_1}");
        儲存全域變數(key = "chunk_available_stack_1", type = "int", value = "{chunk_available_stack_2}");
        儲存全域變數(key = "chunk_available_stack_2", type = "int", value = "{chunk_available_stack_3}");
        儲存全域變數(key = "chunk_available_stack_3", type = "int", value = "{chunk_available_stack_4}");
        儲存全域變數(key = "chunk_available_stack_4", type = "int", value = "{chunk_available_stack_5}");
        儲存全域變數(key = "chunk_available_stack_5", type = "int", value = "{chunk_available_stack_6}");
        儲存全域變數(key = "chunk_available_stack_6", type = "int", value = "{chunk_available_stack_7}");
        儲存全域變數(key = "chunk_available_stack_7", type = "int", value = "{chunk_available_stack_8}");
        儲存全域變數(key = "chunk_available_stack_8", type = "int", value = -1);
        儲存全域變數(key = "map_to_chunk_{instance.map_x}_{instance.map_y}", type = "int", value = "{chunk_available_stack_now}");
        if(((map_x == 99) && (map_y == 100))) {
            地圖::生成地圖("{chunk_{chunk_available_stack_now}_x}", "{chunk_{chunk_available_stack_now}_y}", 地圖::新手村近郊099n100);
        } else if(((map_x == 101) && (map_y == 100))) {
            地圖::生成地圖("{chunk_{chunk_available_stack_now}_x}", "{chunk_{chunk_available_stack_now}_y}", 地圖::新手村近郊101n100);
        } else if(((map_x == 99) && (map_y == 101))) {
            地圖::生成地圖("{chunk_{chunk_available_stack_now}_x}", "{chunk_{chunk_available_stack_now}_y}", 地圖::新手村近郊099n101);
        } else if(((map_x == 100) && (map_y == 101))) {
            地圖::生成地圖("{chunk_{chunk_available_stack_now}_x}", "{chunk_{chunk_available_stack_now}_y}", 地圖::新手村近郊100n101);
        } else if(((map_x == 101) && (map_y == 101))) {
            地圖::生成地圖("{chunk_{chunk_available_stack_now}_x}", "{chunk_{chunk_available_stack_now}_y}", 地圖::新手村近郊101n101);
        } else if(((map_x == 99) && (map_y == 102))) {
            地圖::生成地圖("{chunk_{chunk_available_stack_now}_x}", "{chunk_{chunk_available_stack_now}_y}", 地圖::新手村近郊099n102);
        } else if(((map_x == 100) && (map_y == 102))) {
            地圖::生成地圖("{chunk_{chunk_available_stack_now}_x}", "{chunk_{chunk_available_stack_now}_y}", 地圖::新手村近郊100n102);
        } else if(((map_x == 101) && (map_y == 102))) {
            地圖::生成地圖("{chunk_{chunk_available_stack_now}_x}", "{chunk_{chunk_available_stack_now}_y}", 地圖::新手村近郊101n102);
        }
        儲存全域變數(key = "chunk_to_map_{chunk_available_stack_now}_x", type = "int", value = "{instance.map_x}");
        儲存全域變數(key = "chunk_to_map_{chunk_available_stack_now}_y", type = "int", value = "{instance.map_y}");
        儲存全域變數(key = "map_used_{instance.map_x}_{instance.map_y}", type = "int", value = 1);
        儲存全域變數(key = "chunk_entering_{chunk_available_stack_now}", type = "int", value = 1);
        儲存全域變數(key = "chunk_used_{chunk_available_stack_now}", type = "int", value = 1);
        儲存全域變數(key = "chunk_available_stack_now", type = "int", value = -1);
    }
}
def 地圖::移動離開泛型(direction) : block {
    __repeat__ = -1;
    __label__ = "地圖";
    triggers {
        鍵盤按鍵(varName = "clicker", key = "Space");
    }
    checks {
        if((direction == "右")) {
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = ">=", rhs = "19*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = "<=", rhs = "20*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = ">=", rhs = "9*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = "<=", rhs = "11*32");
            比較數字(lhs = "{map_{{clicker.id}.map_x}_{{clicker.id}.map_y}_ExE}", op = "==", rhs = 1);
        } else if((direction == "左")) {
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = ">=", rhs = "0*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = "<=", rhs = "1*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = ">=", rhs = "9*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = "<=", rhs = "11*32");
            比較數字(lhs = "{map_{{clicker.id}.map_x}_{{clicker.id}.map_y}_ExW}", op = "==", rhs = 1);
        } else if((direction == "下")) {
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = ">=", rhs = "19*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = "<=", rhs = "20*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = ">=", rhs = "9*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = "<=", rhs = "11*32");
            比較數字(lhs = "{map_{{clicker.id}.map_x}_{{clicker.id}.map_y}_ExS}", op = "==", rhs = 1);
        } else if((direction == "上")) {
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = ">=", rhs = "0*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = "<=", rhs = "1*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = ">=", rhs = "9*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = "<=", rhs = "11*32");
            比較數字(lhs = "{map_{{clicker.id}.map_x}_{{clicker.id}.map_y}_ExN}", op = "==", rhs = 1);
        }
    }
    actions {
        setGlobal(key = "instance", type = "string", value = "{clicker.id}");
        自定義::儲存Instance整數("tmp_grid_x_offset", "({instance.gamePosition.x}%864)/32");
        自定義::儲存Instance整數("tmp_grid_y_offset", "({instance.gamePosition.y}%864)/32");
        if(除錯模式) {
            print(text = ("x: {instance.map_x}, y: {instance.map_y}, direction: " + direction), type = "error");
            print(text = "x_offset: {instance.tmp_grid_x_offset}, y_offset: {instance.tmp_grid_x_offset}", type = "error");
        }
        儲存物件變數(key = "map_direction", object = "instance", type = "string", value = direction);
        if((direction == "右")) {
            自定義::儲存Instance整數("map_x", "{instance.map_x}+1");
        } else if((direction == "左")) {
            自定義::儲存Instance整數("map_x", "{instance.map_x}-1");
        } else if((direction == "下")) {
            自定義::儲存Instance整數("map_y", "{instance.map_y}+1");
        } else if((direction == "上")) {
            自定義::儲存Instance整數("map_y", "{instance.map_y}-1");
        }
        移動角色位置(actorId = "instance", x = 23, y = 23);
    }
}
def 地圖::移動進入泛型(direction) : block {
    __repeat__ = -1;
    __label__ = "地圖";
    checks {
        找出所有角色(actor = 角色::任何玩家, varname = "instance");
        角色所在區域(actorId = "instance", region_h = 1, region_w = 1, region_x = 23, region_y = 23);
        比較數字(lhs = "{map_used_{instance.map_x}_{instance.map_y}}", op = "==", rhs = "1");
        比對字串(str = direction, value = "{instance.map_direction}");
    }
    actions {
        if((direction == "右")) {
            移動角色位置(actorId = "instance", x = "{chunk_{map_to_chunk_{instance.map_x}_{instance.map_y}}_x}", y = "{chunk_{map_to_chunk_{instance.map_x}_{instance.map_y}}_y} + {instance.tmp_grid_y_offset}");
        } else if((direction == "左")) {
            移動角色位置(actorId = "instance", x = "{chunk_{map_to_chunk_{instance.map_x}_{instance.map_y}}_x} + 19", y = "{chunk_{map_to_chunk_{instance.map_x}_{instance.map_y}}_y} + {instance.tmp_grid_y_offset}");
        } else if((direction == "下")) {
            移動角色位置(actorId = "instance", x = "{chunk_{map_to_chunk_{instance.map_x}_{instance.map_y}}_x} + {instance.tmp_grid_x_offset}", y = "{chunk_{map_to_chunk_{instance.map_x}_{instance.map_y}}_y}");
        } else if((direction == "上")) {
            移動角色位置(actorId = "instance", x = "{chunk_{map_to_chunk_{instance.map_x}_{instance.map_y}}_x} + {instance.tmp_grid_x_offset}", y = "{chunk_{map_to_chunk_{instance.map_x}_{instance.map_y}}_y} + 19");
        }
        等待(duration = 1000);
        儲存全域變數(key = "chunk_entering_{map_to_chunk_{instance.map_x}_{instance.map_y}}", type = "int", value = 0);
    }
}
def 地圖::移動移除物件泛型(chunk_id) : block {
    __repeat__ = -1;
    __label__ = "地圖";
    checks {
        計算人數(actor = 角色::任何玩家, op = "==", value = 0, region_h = 20, region_w = 20, region_x = ((chunk_id % 3) * 27), region_y = ((chunk_id / 3) * 27));
        比較數字(lhs = ("{chunk_entering_" + (twge::to_string(chunk_id) + "}")), op = "==", rhs = 0);
        比較數字(lhs = ("{chunk_used_" + (twge::to_string(chunk_id) + "}")), op = "==", rhs = 1);
    }
    actions {
        移除地圖機關(region_h = 20, region_w = 20, region_x = ((chunk_id % 3) * 27), region_y = ((chunk_id / 3) * 27));
        移除地圖物件(region_h = 20, region_w = 20, region_x = ((chunk_id % 3) * 27), region_y = ((chunk_id / 3) * 27));
        儲存全域變數(key = ("chunk_used_" + twge::to_string(chunk_id)), type = "int", value = 0);
        儲存全域變數(key = "map_tmp_to_release_x", type = "int", value = ("{chunk_to_map_" + (twge::to_string(chunk_id) + "_x}")));
        儲存全域變數(key = "map_tmp_to_release_y", type = "int", value = ("{chunk_to_map_" + (twge::to_string(chunk_id) + "_y}")));
        儲存全域變數(key = "map_used_{map_tmp_to_release_x}_{map_tmp_to_release_y}", type = "int", value = 0);
        儲存全域變數(key = "map_to_chunk_{map_tmp_to_release_x}_{map_tmp_to_release_y}", type = "int", value = -1);
        儲存全域變數(key = "chunk_available_stack_8", type = "int", value = chunk_id);
    }
}
def 地圖::移動移除人物泛型(chunk_id) : block {
    __repeat__ = -1;
    __label__ = "地圖";
    checks {
        比較數字(lhs = ("{chunk_used_" + (twge::to_string(chunk_id) + "}")), op = "==", rhs = 0);
        找出所有角色(actor = 角色::任何電腦, varname = "instance");
        角色所在區域(actorId = "instance", region_h = 20, region_w = 20, region_x = ((chunk_id % 3) * 27), region_y = ((chunk_id / 3) * 27), checkAlive = true);
    }
    actions {
        角色消失(actorId = "instance");
    }
}
def 面板::顯示能力面板() : actions {
    彈出選項視窗(actorId = "{instance}", dialogId = "dialog_point", message = 面板::能力頁, options = [Button(id = "dialog_button_point_STR_01", text = "分配一點力量"),Button(id = "dialog_button_point_STR_10", text = "分配十點力量"),Button(id = "dialog_button_point_CON_01", text = "分配一點體質"),Button(id = "dialog_button_point_CON_10", text = "分配十點體質"),Button(id = "dialog_button_point_AGI_01", text = "分配一點敏捷"),Button(id = "dialog_button_point_AGI_10", text = "分配十點敏捷"),Button(id = "dialog_button_point_INT_01", text = "分配一點智慧"),Button(id = "dialog_button_point_INT_10", text = "分配十點智慧"),Button(id = "dialog_button_point_PSY_01", text = "分配一點精神"),Button(id = "dialog_button_point_PSY_10", text = "分配十點精神")]);
}
def 面板::點擊能力分配泛型(type, typeZh, value) : block {
    __repeat__ = -1;
    __label__ = "面板";
    triggers {
        視窗確認(buttonName = ("dialog_button_point_" + (type + ("_" + value))), playerLocalId = "instance");
    }
    checks {
        比較數字(lhs = "{instance.Point}", op = ">=", rhs = value);
    }
    actions {
        關閉彈出視窗(actorId = "{instance}", dialogId = "dialog_point");
        自定義::儲存Instance整數("Point", ("{instance.Point} - " + value));
        自定義::儲存Instance整數(type, ("{instance." + (type + ("} + " + value))));
        自定義::更新角色屬性("instance");
        自定義::上載Instance數據();
        面板::顯示能力面板();
    }
}
