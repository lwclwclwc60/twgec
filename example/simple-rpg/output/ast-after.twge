block 移動生成100_102 {
    __repeat__ = -1;
    __label__ = "地圖";
    checks {
        找出所有角色(actor = ActorMatch(controller = "player"), varname = "instance");
        角色所在區域(actorId = "instance", region_h = 1, region_w = 1, region_x = 23, region_y = 23);
        比較數字(lhs = "{map_used_{instance.map_x}_{instance.map_y}}", op = "==", rhs = "0");
        比較數字(lhs = "{instance.map_x}", op = "==", rhs = 100);
        比較數字(lhs = "{instance.map_y}", op = "==", rhs = 102);
        比較數字(lhs = "{chunk_available_stack_0}", op = "!=", rhs = -1);
        比較數字(lhs = "{chunk_available_stack_now}", op = "==", rhs = -1);
    }
    actions {
