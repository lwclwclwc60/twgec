block 地圖移動離開往上 {
    __repeat__ = -1;
    __label__ = "地圖";
    triggers {
        鍵盤按鍵(varName = "clicker", key = "Space");
    }
    checks {
        if(("上" == "右")) {
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = ">=", rhs = "19*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = "<=", rhs = "20*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = ">=", rhs = "9*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = "<=", rhs = "11*32");
            比較數字(lhs = "{map_{{clicker.id}.map_x}_{{clicker.id}.map_y}_ExE}", op = "==", rhs = 1);
        } else if(("上" == "左")) {
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = ">=", rhs = "0*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = "<=", rhs = "1*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = ">=", rhs = "9*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = "<=", rhs = "11*32");
            比較數字(lhs = "{map_{{clicker.id}.map_x}_{{clicker.id}.map_y}_ExW}", op = "==", rhs = 1);
        } else if(("上" == "下")) {
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = ">=", rhs = "19*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = "<=", rhs = "20*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = ">=", rhs = "9*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = "<=", rhs = "11*32");
            比較數字(lhs = "{map_{{clicker.id}.map_x}_{{clicker.id}.map_y}_ExS}", op = "==", rhs = 1);
        } else if(("上" == "上")) {
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = ">=", rhs = "0*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = "<=", rhs = "1*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = ">=", rhs = "9*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = "<=", rhs = "11*32");
            比較數字(lhs = "{map_{{clicker.id}.map_x}_{{clicker.id}.map_y}_ExN}", op = "==", rhs = 1);
        }
    }
    actions {
        setGlobal(key = "instance", type = "string", value = "{clicker.id}");
        自定義::儲存Instance整數(key = "tmp_grid_x_offset", value = "({instance.gamePosition.x}%864)/32");
        自定義::儲存Instance整數(key = "tmp_grid_y_offset", value = "({instance.gamePosition.y}%864)/32");
        if(除錯模式) {
            print(text = ("x: {instance.map_x}, y: {instance.map_y}, direction: " + "上"), type = "error");
            print(text = "x_offset: {instance.tmp_grid_x_offset}, y_offset: {instance.tmp_grid_x_offset}", type = "error");
        }
        儲存物件變數(key = "map_direction", object = "instance", type = "string", value = "上");
        if(("上" == "右")) {
            自定義::儲存Instance整數(key = "map_x", value = "{instance.map_x}+1");
        } else if(("上" == "左")) {
            自定義::儲存Instance整數(key = "map_x", value = "{instance.map_x}-1");
        } else if(("上" == "下")) {
            自定義::儲存Instance整數(key = "map_y", value = "{instance.map_y}+1");
        } else if(("上" == "上")) {
            自定義::儲存Instance整數(key = "map_y", value = "{instance.map_y}-1");
        }
        移動角色位置(actorId = "instance", x = 23, y = 23);
    }
}
