                計算人數(actor = ActorMatch(id = "monster_deer_lv01", matchKind = "contain"), op = "<", value = 2);
            } else {
                計算人數(actor = ActorMatch(id = "monster_deer_lv01", matchKind = "contain"), op = "<", value = 4);
            }
        }
        if(false) {
            計算人數(actor = ActorMatch(id = "monster_stone_lv01", matchKind = "contain"), op = "<", value = 1);
