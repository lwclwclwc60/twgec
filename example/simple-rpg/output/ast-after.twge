    }
}
block 點擊能力分配一點力量 = 面板::點擊能力分配泛型(type = "STR", typeZh = "力量", value = "01");
block 點擊能力分配一點體質 = 面板::點擊能力分配泛型(type = "CON", typeZh = "體質", value = "01");
block 點擊能力分配一點敏捷 = 面板::點擊能力分配泛型(type = "AGI", typeZh = "敏捷", value = "01");
block 點擊能力分配一點智慧 = 面板::點擊能力分配泛型(type = "INT", typeZh = "智慧", value = "01");
block 點擊能力分配一點精神 = 面板::點擊能力分配泛型(type = "PSY", typeZh = "精神", value = "01");
block 點擊能力分配十點力量 = 面板::點擊能力分配泛型(type = "STR", typeZh = "力量", value = "10");
block 點擊能力分配十點體質 = 面板::點擊能力分配泛型(type = "CON", typeZh = "體質", value = "10");
block 點擊能力分配十點敏捷 = 面板::點擊能力分配泛型(type = "AGI", typeZh = "敏捷", value = "10");
block 點擊能力分配十點智慧 = 面板::點擊能力分配泛型(type = "INT", typeZh = "智慧", value = "10");
block 點擊能力分配十點精神 = 面板::點擊能力分配泛型(type = "PSY", typeZh = "精神", value = "10");
block 點擊重置能力 {
    __repeat__ = -1;
    __label__ = "玩家";
    triggers {
        告示牌按鈕(varName = "instance", buttonId = "ResetPoint");
    }
    actions {
        自定義::儲存Instance整數(key = "Point", value = "{instance.Level}*2+3");
        自定義::儲存Instance整數(key = "STR", value = 0);
        自定義::儲存Instance整數(key = "CON", value = 0);
        自定義::儲存Instance整數(key = "AGI", value = 0);
        自定義::儲存Instance整數(key = "INT", value = 0);
        自定義::儲存Instance整數(key = "PSY", value = 0);
        角色說話(actorId = "instance", text = "成功重設能力點，目前有{instance.Point}點能力點");
        自定義::更新角色屬性(actorId = "instance");
        自定義::上載Instance數據();
    }
}
block 等級提升 {
    __repeat__ = -1;
    __label__ = "玩家";
    checks {
        找出所有角色(actor = 角色::任何玩家, varname = "instance");
        比較數字(lhs = "{instance.Exp}", op = ">=", rhs = "{instance.ExpNeeded}");
    }
    actions {
        地圖標示文字(x = 公式::InstanceX坐標, y = 公式::InstanceY坐標, html = true, text = 文字::HTML等級提升, duration = 6000);
        自定義::儲存Instance整數(key = "Exp", value = "{instance.Exp}-{instance.ExpNeeded}");
        自定義::儲存Instance整數(key = "Level", value = "{instance.Level}+1");
        自定義::儲存Instance整數(key = "Point", value = "{instance.Point}+2");
        自定義::儲存Instance整數(key = "ExpNeeded", value = "{instance.Level}*2+4");
        自定義::儲存Instance整數(key = "HP", value = 公式::Instance血量);
        設定角色屬性(actorId = "instance", attr = "maxHp", value = "{instance.HP}");
        自定義::上載Instance數據();
    }
}
block 回血 {
    __repeat__ = -1;
    __repeatInterval__ = 10000;
    __label__ = "玩家";
    checks {
        找出所有角色(actor = 角色::任何玩家, varname = "instance");
    }
    actions {
        角色加減血(actorCode = "instance", value = 公式::Instance恢復量);
    }
}
block 玩家死亡 {
    __repeat__ = -1;
    __label__ = "玩家";
    triggers {
        角色死亡(actor = 角色::任何玩家, varName = "instance");
    }
    actions {
        自定義::儲存Instance整數(key = "map_x", value = 100);
        自定義::儲存Instance整數(key = "map_y", value = 100);
    }
}
block 玩家初始化 {
    __repeat__ = -1;
    __label__ = "玩家";
    triggers {
        角色進入戰場(actor = 角色::任何玩家, varName = "instance");
    }
    actions {
        自定義::儲存Instance整數(key = "STR", value = 0);
        自定義::儲存Instance整數(key = "CON", value = 0);
        自定義::儲存Instance整數(key = "AGI", value = 0);
        自定義::儲存Instance整數(key = "INT", value = 0);
        自定義::儲存Instance整數(key = "PSY", value = 0);
        自定義::儲存Instance整數(key = "Level", value = 1);
        自定義::儲存Instance整數(key = "Point", value = 5);
        自定義::儲存Instance整數(key = "Exp", value = 0);
        自定義::儲存Instance整數(key = "ExpNeeded", value = 6);
        自定義::儲存Instance整數(key = "HP", value = 100);
        自定義::儲存Instance整數(key = "map_x", value = 100);
        自定義::儲存Instance整數(key = "map_y", value = 100);
        儲存物件變數(key = "XSkill", object = "instance", type = "string", value = "無");
        取得玩家狀態(category = 狀態讀寫密鑰, key = "savedBefore", playerId = "{instance}", varName = "{instance}_savedBefore");
        人物裝備武器(actorCode = "instance", type = "fist", hand = 1);
        人物裝備武器(actorCode = "instance", type = "fist", hand = 2);
        角色說話(actorId = "instance", cleanTalk = true, text = "玩家初始中");
        設定角色屬性(actorId = "instance", attr = "group", value = "100");
        等待(duration = 500);
        自定義::儲存Instance整數(key = "completedInit", value = 1);
        for(x in 0...2) {
            for(y in 0...2) {
                角色重生位置(actorId = "{instance}", x = (x * 27), y = (y * 27));
            }
        }
        角色重生位置(actorId = "{instance}", x = 23, y = 23);
        角色重生位置(actorId = "{instance}", x = 10, y = 10);
    }
}
block 遊戲初始化 {
    actions {
        迴避友軍攻擊();
    }
}
