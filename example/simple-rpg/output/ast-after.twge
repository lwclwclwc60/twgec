    actions {
        if(true) {
            新增角色(name = "鹿(Lv1)", id = "monster_deer_lv01*", hp = 60, strength = 10, x = "{chunk_{map_to_chunk_99_100}_x} + 10", y = "{chunk_{map_to_chunk_99_100}_y} + 10", camp = "第三", range = 10, localVarname = "actor", weapon1 = "fist", weapon2 = "fist", teamId = 101, role = "鹿");
        }
        if(false) {
            新增角色(name = "鹿(Lv1)", id = "monster_stone_lv01*", hp = 100, strength = 10, x = "{chunk_{map_to_chunk_99_100}_x} + 10", y = "{chunk_{map_to_chunk_99_100}_y} + 10", camp = "第三", range = 10, localVarname = "actor", weapon1 = "fist", weapon2 = "fist", teamId = 101, role = "石怪");
            設定角色屬性(actorId = "{actor}", attr = "體重", value = "6");
            設定角色屬性(actorId = "{actor}", attr = "體型縮放", value = "1.1");
