        新增地圖物件(x = x, y = y, object = "白光(下)");
    } else if((object == "ExW")) {
        新增地圖物件(x = x, y = y, object = "白光(左)");
    } else {
        twge::assert(false, ("無效地圖物件: " + object));
    }
