def 自定義::野獸重生泛型(interval, chunk_x, chunk_y, monster_type, level) : block {
    __repeat__ = -1;
    __repeatInterval__ = interval;
    __delay__ = 1000;
    __label__ = "怪物";
    checks {
        if((monster_type == "鹿")) {
            if(((chunk_x == "101") && (chunk_y == "102"))) {
                計算人數(actor = ActorMatch(id = ("monster_deer_lv0" + twge::to_string(level)), matchKind = "contain"), op = "<", value = 2);
            } else {
                計算人數(actor = ActorMatch(id = ("monster_deer_lv0" + twge::to_string(level)), matchKind = "contain"), op = "<", value = 4);
            }
        }
        if((monster_type == "山嶺石怪")) {
            計算人數(actor = ActorMatch(id = ("monster_stone_lv0" + twge::to_string(level)), matchKind = "contain"), op = "<", value = 1);
        }
        比較數字(lhs = ("{map_used_" + (chunk_x + ("_" + (chunk_y + "}")))), op = "==", rhs = "1");
    }
    actions {
        if((monster_type == "鹿")) {
            新增角色(name = (monster_type + ("(Lv" + (twge::to_string(level) + ")"))), id = ("monster_deer_lv0" + (twge::to_string(level) + "*")), hp = (15 + (45 * level)), strength = (5 + (5 * level)), x = ("{chunk_{map_to_chunk_" + (chunk_x + ("_" + (chunk_y + "}_x} + 10")))), y = ("{chunk_{map_to_chunk_" + (chunk_x + ("_" + (chunk_y + "}_y} + 10")))), camp = "第三", range = 10, localVarname = "actor", weapon1 = "fist", weapon2 = "fist", teamId = 101, role = "鹿");
        }
        if((monster_type == "山嶺石怪")) {
            新增角色(name = (monster_type + ("(Lv" + (twge::to_string(level) + ")"))), id = ("monster_stone_lv0" + (twge::to_string(level) + "*")), hp = (20 + (80 * level)), strength = (10 * level), x = ("{chunk_{map_to_chunk_" + (chunk_x + ("_" + (chunk_y + "}_x} + 10")))), y = ("{chunk_{map_to_chunk_" + (chunk_x + ("_" + (chunk_y + "}_y} + 10")))), camp = "第三", range = 10, localVarname = "actor", weapon1 = "fist", weapon2 = "fist", teamId = 101, role = "石怪");
            設定角色屬性(actorId = "{actor}", attr = "體重", value = "6");
            設定角色屬性(actorId = "{actor}", attr = "體型縮放", value = "1.1");
        }
        跟隨人物(actorId = "actor", type = "跟隨自己");
    }
}
def 自定義::點擊設定技能泛型(name, nameZh) : block {
    __repeat__ = -1;
    __label__ = "技能";
    triggers {
        告示牌按鈕(varName = "instance", buttonId = ("setX" + name));
    }
    actions {
        儲存物件變數(key = "XSkill", object = "instance", type = "string", value = nameZh);
    }
}
def 火星領域技能() : actions {
    EnhFF::玩家滑鼠座標(actorId = "{instance}", varX = "x", varY = "y");
    EnhFF::廣義圓形範圍(x = "{x}", y = "{y}", radius = (2 * 64), duration = 10000, color = "#912B2B", lineWidth = 3);
    for(i in 1...30) {
        wait(duration = 300);
        EnhFF::廣義圓形範圍(x = "{x}+random(-64,64)", y = "{y}+random(-64,64)", radius = 40, duration = 500, color = "#FF0F0F", deltaHpType = "damage", deltaHpValue = 公式::火星領域傷害, deltaHpCD = 4000, deltaHpTarget = 角色::任何敵軍);
    }
    wait(duration = 10000);
}
def 震撼技能() : actions {
    EnhFF::廣義圓形範圍(actorId = "instance", radius = 公式::震撼範圍, duration = 2000, color = "#CC7700", deltaHpType = "damage", lineWidth = 3, deltaHpValue = 公式::震撼傷害, deltaHpCD = 4000, deltaHpTarget = 角色::任何敵軍);
    wait(duration = 12000);
}
def 土靈召喚技能() : actions {
    儲存全域變數(key = "tmp", type = "int", value = 公式::土靈召喚血量);
    新增角色(name = "土靈({tmp})", id = "earthSpirit*", camp = "第三", hp = 公式::土靈召喚血量, x = 公式::InstanceX坐標, y = 公式::InstanceY坐標, localVarname = "actor", weapon1 = "fist", weapon2 = "fist", teamId = 100, strength = 公式::土靈召喚傷害, role = "不動佛");
    跟隨人物(actorId = "actor", type = "跟隨人物", targetId = "{instance}");
    wait(duration = 35000);
    角色消失(actorId = "actor");
    wait(duration = 5000);
}
def 自定義::觸發技能泛型(name, nameZh, color) : block {
    __repeat__ = -1;
    __label__ = "技能";
    triggers {
        鍵盤按鍵(varName = "clicker", key = "X");
    }
    checks {
        比對字串(matchKind = "equal", str = nameZh, value = "{{clicker.id}.XSkill}");
        比較數字(lhs = ("{{clicker.id}.skill" + (name + "CD}")), op = "!=", rhs = 1);
    }
    actions {
        setGlobal(key = "instance", type = "string", value = "{clicker.id}");
        地圖標示文字(x = 公式::InstanceX坐標, y = 公式::InstanceY坐標, html = true, text = ("<span style='color: " + (color + ("'>" + (nameZh + "</span>")))));
        自定義::儲存Instance整數(key = ("skill" + (name + "CD")), value = 1);
        if((name == 別名::技能火星領域EN)) {
            火星領域技能();
        }
        if((name == 別名::技能震撼EN)) {
            震撼技能();
        }
        if((name == 別名::技能土靈召喚EN)) {
            土靈召喚技能();
        }
        自定義::儲存Instance整數(key = ("skill" + (name + "CD")), value = 0);
        地圖標示文字(x = 公式::InstanceX坐標, y = 公式::InstanceY坐標, html = true, text = ("<span style='color: " + (color + ("'>" + (nameZh + "冷卻完畢</span>")))));
    }
}
def 地圖::生成地圖配置(x, y, object) : actions {
    if(((object == "---") || (object == " . "))) {
    } else if((object == "SP0")) {
        新增地圖物件(x = x, y = y, object = "石椅");
        新增告示牌(x = x, y = y, rotation = 180, text = "【重置能力點分配】", buttons = [Button(id = "ResetPoint", text = "確認")]);
    } else if((object == "SW1")) {
        新增地圖物件(x = x, y = y, object = "小箱子");
        新增告示牌(x = x, y = y, rotation = 90, text = 文字::風杖描述, buttons = [Button(id = "wearWindStaff", text = "裝備"),Button(id = "wearNone", text = "卸下")]);
    } else if((object == "SW2")) {
        新增地圖物件(x = x, y = y, object = "小箱子");
        新增告示牌(x = x, y = y, rotation = 90, text = 文字::匕首描述, buttons = [Button(id = "wearDagger", text = "裝備"),Button(id = "wearNone", text = "卸下")]);
    } else if((object == "SW3")) {
        新增地圖物件(x = x, y = y, object = "小箱子");
        新增告示牌(x = x, y = y, rotation = 90, text = 文字::鐵劍描述, buttons = [Button(id = "wearIronSword", text = "裝備"),Button(id = "wearNone", text = "卸下")]);
    } else if((object == "SS1")) {
        新增地圖物件(x = x, y = y, object = "小箱子");
        新增告示牌(x = x, y = y, rotation = 180, text = 文字::火星領域描述, buttons = [Button(id = ("setX" + 別名::技能火星領域EN), text = "設置於X鍵"),Button(id = "setXNone", text = "卸下")]);
    } else if((object == "SS2")) {
        新增地圖物件(x = x, y = y, object = "小箱子");
        新增告示牌(x = x, y = y, rotation = 180, text = 文字::震撼描述, buttons = [Button(id = ("setX" + 別名::技能震撼EN), text = "設置於X鍵"),Button(id = "setXNone", text = "卸下")]);
    } else if((object == "SS3")) {
        新增地圖物件(x = x, y = y, object = "小箱子");
        新增告示牌(x = x, y = y, rotation = 180, text = 文字::土靈召喚, buttons = [Button(id = ("setX" + 別名::技能土靈召喚EN), text = "設置於X鍵"),Button(id = "setXNone", text = "卸下")]);
    } else if((object == "DM0")) {
        新增回氣魔法陣(x = x, y = y, heal = "10", healActorCooldown = "4000", healDeviceCooldown = "1000");
    } else if((object == "NP1")) {
        新增角色(name = "武器商人", id = "npc01*", camp = "第三", x = x, y = y, rotation = 90, weapon1 = "fist", weapon2 = "fist", teamId = 100, role = "隱居士");
    } else if((object == "NP2")) {
        新增角色(name = "技能商人", id = "npc02*", camp = "第三", x = x, y = y, rotation = 180, weapon1 = "fist", weapon2 = "fist", teamId = 100, role = "赤焰精靈");
    } else if((object == "NP3")) {
        新增角色(name = "祭司", id = "npc03*", camp = "第三", x = x, y = y, rotation = 270, weapon1 = "fist", weapon2 = "fist", teamId = 100, role = "男靈能訓練官");
    } else if((object == "NP4")) {
        新增角色(name = "村長", id = "npc04*", camp = "第三", x = x, y = y, rotation = 0, weapon1 = "fist", weapon2 = "fist", teamId = 100, externRole = "TWilightGameEventCompiler.character_village_head");
    } else if((object == "LBx")) {
        新增地圖物件(x = x, y = y, object = "大箱子", walkable = false);
    } else if((object == "SBx")) {
        新增地圖物件(x = x, y = y, object = "小箱子", walkable = false);
    } else if((object == "H00")) {
        新增地圖物件(x = x, y = y, object = "5x4橫向房子", walkable = false);
    } else if((object == "H01")) {
        新增地圖物件(x = x, y = y, object = "5x4縱向房子", walkable = false);
    } else if((object == "***")) {
        新增地圖物件(x = x, y = y, object = "草地");
    } else if((object == "t00")) {
        新增地圖物件(x = x, y = y, object = "3x3綠樹");
    } else if((object == "r00")) {
        新增地圖物件(x = x, y = y, object = "3x3黑石");
    } else if((object == "r01")) {
        新增地圖物件(x = x, y = y, object = "3x3金石");
    } else if((object == "r02")) {
        新增地圖物件(x = x, y = y, object = "2x2白石");
    } else if((object == "r03")) {
        新增地圖物件(x = x, y = y, object = "1x1黑石");
    } else if((object == "r04")) {
        新增地圖物件(x = x, y = y, object = "1x1金石");
    } else if((object == "r05")) {
        新增地圖物件(x = x, y = y, object = "2x2棕石");
    } else if((object == "ExN")) {
        新增地圖物件(x = x, y = y, object = "白光(上)");
    } else if((object == "ExE")) {
        新增地圖物件(x = x, y = y, object = "白光(右)");
    } else if((object == "ExS")) {
        新增地圖物件(x = x, y = y, object = "白光(下)");
    } else if((object == "ExW")) {
        新增地圖物件(x = x, y = y, object = "白光(左)");
    } else {
        twge::assert(false, ("無效地圖物件: " + object));
    }
}
def 地圖::生成地圖(xOffset, yOffset, mapArray) : actions {
    print(text = ("xOffset:" + xOffset));
    print(text = ("yOffset:" + yOffset));
    for(map_row in 0...(twge::get_length(mapArray) - 1)) {
        for(map_col in 0...((twge::get_length(twge::get_index(mapArray, map_row)) / 3) - 1)) {
            地圖::生成地圖配置(x = (twge::to_string(map_col) + ("+" + xOffset)), y = (twge::to_string(map_row) + ("+" + yOffset)), object = twge::get_slice(twge::get_index(mapArray, map_row), ((map_col * 3) + 0), ((map_col * 3) + 2)));
        }
    }
}
def 地圖::儲存地圖變量(x, y, map) : actions {
    if((twge::get_slice(twge::get_index(map, 0), 27, 32) == "ExNExN")) {
        儲存全域變數(key = ("map_" + (twge::to_string(x) + ("_" + (twge::to_string(y) + "_ExN")))), type = "int", value = 1);
    }
    if((twge::get_slice(twge::get_index(map, 19), 27, 32) == "ExSExS")) {
        儲存全域變數(key = ("map_" + (twge::to_string(x) + ("_" + (twge::to_string(y) + "_ExS")))), type = "int", value = 1);
    }
    if(((twge::get_slice(twge::get_index(map, 9), 0, 2) == "ExW") && (twge::get_slice(twge::get_index(map, 10), 0, 2) == "ExW"))) {
        儲存全域變數(key = ("map_" + (twge::to_string(x) + ("_" + (twge::to_string(y) + "_ExW")))), type = "int", value = 1);
    }
    if(((twge::get_slice(twge::get_index(map, 9), 57, 59) == "ExE") && (twge::get_slice(twge::get_index(map, 10), 57, 59) == "ExE"))) {
        儲存全域變數(key = ("map_" + (twge::to_string(x) + ("_" + (twge::to_string(y) + "_ExE")))), type = "int", value = 1);
    }
    儲存全域變數(key = ("map_used_" + (twge::to_string(x) + ("_" + twge::to_string(y)))), type = "int", value = 0);
}
def 地圖::移動生成泛型(map_x, map_y) : block {
    __repeat__ = -1;
    __label__ = "地圖";
    checks {
        找出所有角色(actor = 角色::任何玩家, varname = "instance");
        角色所在區域(actorId = "instance", region_h = 1, region_w = 1, region_x = 23, region_y = 23);
        比較數字(lhs = "{map_used_{instance.map_x}_{instance.map_y}}", op = "==", rhs = "0");
        比較數字(lhs = "{instance.map_x}", op = "==", rhs = map_x);
        比較數字(lhs = "{instance.map_y}", op = "==", rhs = map_y);
        比較數字(lhs = "{chunk_available_stack_0}", op = "!=", rhs = -1);
        比較數字(lhs = "{chunk_available_stack_now}", op = "==", rhs = -1);
    }
    actions {
        儲存全域變數(key = "chunk_available_stack_now", type = "int", value = "{chunk_available_stack_0}");
        儲存全域變數(key = "chunk_available_stack_0", type = "int", value = "{chunk_available_stack_1}");
        儲存全域變數(key = "chunk_available_stack_1", type = "int", value = "{chunk_available_stack_2}");
        儲存全域變數(key = "chunk_available_stack_2", type = "int", value = "{chunk_available_stack_3}");
        儲存全域變數(key = "chunk_available_stack_3", type = "int", value = "{chunk_available_stack_4}");
        儲存全域變數(key = "chunk_available_stack_4", type = "int", value = "{chunk_available_stack_5}");
        儲存全域變數(key = "chunk_available_stack_5", type = "int", value = "{chunk_available_stack_6}");
        儲存全域變數(key = "chunk_available_stack_6", type = "int", value = "{chunk_available_stack_7}");
        儲存全域變數(key = "chunk_available_stack_7", type = "int", value = "{chunk_available_stack_8}");
        儲存全域變數(key = "chunk_available_stack_8", type = "int", value = -1);
        儲存全域變數(key = "map_to_chunk_{instance.map_x}_{instance.map_y}", type = "int", value = "{chunk_available_stack_now}");
        if(((map_x == 99) && (map_y == 100))) {
            地圖::生成地圖(xOffset = "{chunk_{chunk_available_stack_now}_x}", yOffset = "{chunk_{chunk_available_stack_now}_y}", mapArray = 地圖::新手村近郊099n100);
        } else if(((map_x == 101) && (map_y == 100))) {
            地圖::生成地圖(xOffset = "{chunk_{chunk_available_stack_now}_x}", yOffset = "{chunk_{chunk_available_stack_now}_y}", mapArray = 地圖::新手村近郊101n100);
        } else if(((map_x == 99) && (map_y == 101))) {
            地圖::生成地圖(xOffset = "{chunk_{chunk_available_stack_now}_x}", yOffset = "{chunk_{chunk_available_stack_now}_y}", mapArray = 地圖::新手村近郊099n101);
        } else if(((map_x == 100) && (map_y == 101))) {
            地圖::生成地圖(xOffset = "{chunk_{chunk_available_stack_now}_x}", yOffset = "{chunk_{chunk_available_stack_now}_y}", mapArray = 地圖::新手村近郊100n101);
        } else if(((map_x == 101) && (map_y == 101))) {
            地圖::生成地圖(xOffset = "{chunk_{chunk_available_stack_now}_x}", yOffset = "{chunk_{chunk_available_stack_now}_y}", mapArray = 地圖::新手村近郊101n101);
        } else if(((map_x == 99) && (map_y == 102))) {
            地圖::生成地圖(xOffset = "{chunk_{chunk_available_stack_now}_x}", yOffset = "{chunk_{chunk_available_stack_now}_y}", mapArray = 地圖::新手村近郊099n102);
        } else if(((map_x == 100) && (map_y == 102))) {
            地圖::生成地圖(xOffset = "{chunk_{chunk_available_stack_now}_x}", yOffset = "{chunk_{chunk_available_stack_now}_y}", mapArray = 地圖::新手村近郊100n102);
        } else if(((map_x == 101) && (map_y == 102))) {
            地圖::生成地圖(xOffset = "{chunk_{chunk_available_stack_now}_x}", yOffset = "{chunk_{chunk_available_stack_now}_y}", mapArray = 地圖::新手村近郊101n102);
        }
        儲存全域變數(key = "chunk_to_map_{chunk_available_stack_now}_x", type = "int", value = "{instance.map_x}");
        儲存全域變數(key = "chunk_to_map_{chunk_available_stack_now}_y", type = "int", value = "{instance.map_y}");
        儲存全域變數(key = "map_used_{instance.map_x}_{instance.map_y}", type = "int", value = 1);
        儲存全域變數(key = "chunk_entering_{chunk_available_stack_now}", type = "int", value = 1);
        儲存全域變數(key = "chunk_used_{chunk_available_stack_now}", type = "int", value = 1);
        儲存全域變數(key = "chunk_available_stack_now", type = "int", value = -1);
    }
}
def 地圖::移動離開泛型(direction) : block {
    __repeat__ = -1;
    __label__ = "地圖";
    triggers {
        鍵盤按鍵(varName = "clicker", key = "Space");
    }
    checks {
        if((direction == "右")) {
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = ">=", rhs = "19*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = "<=", rhs = "20*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = ">=", rhs = "9*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = "<=", rhs = "11*32");
            比較數字(lhs = "{map_{{clicker.id}.map_x}_{{clicker.id}.map_y}_ExE}", op = "==", rhs = 1);
        } else if((direction == "左")) {
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = ">=", rhs = "0*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = "<=", rhs = "1*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = ">=", rhs = "9*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = "<=", rhs = "11*32");
            比較數字(lhs = "{map_{{clicker.id}.map_x}_{{clicker.id}.map_y}_ExW}", op = "==", rhs = 1);
        } else if((direction == "下")) {
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = ">=", rhs = "19*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = "<=", rhs = "20*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = ">=", rhs = "9*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = "<=", rhs = "11*32");
            比較數字(lhs = "{map_{{clicker.id}.map_x}_{{clicker.id}.map_y}_ExS}", op = "==", rhs = 1);
        } else if((direction == "上")) {
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = ">=", rhs = "0*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = "<=", rhs = "1*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = ">=", rhs = "9*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = "<=", rhs = "11*32");
            比較數字(lhs = "{map_{{clicker.id}.map_x}_{{clicker.id}.map_y}_ExN}", op = "==", rhs = 1);
        }
    }
    actions {
        setGlobal(key = "instance", type = "string", value = "{clicker.id}");
        自定義::儲存Instance整數(key = "tmp_grid_x_offset", value = "({instance.gamePosition.x}%864)/32");
        自定義::儲存Instance整數(key = "tmp_grid_y_offset", value = "({instance.gamePosition.y}%864)/32");
        if(除錯模式) {
            print(text = ("x: {instance.map_x}, y: {instance.map_y}, direction: " + direction), type = "error");
            print(text = "x_offset: {instance.tmp_grid_x_offset}, y_offset: {instance.tmp_grid_x_offset}", type = "error");
        }
        儲存物件變數(key = "map_direction", object = "instance", type = "string", value = direction);
        if((direction == "右")) {
            自定義::儲存Instance整數(key = "map_x", value = "{instance.map_x}+1");
        } else if((direction == "左")) {
            自定義::儲存Instance整數(key = "map_x", value = "{instance.map_x}-1");
        } else if((direction == "下")) {
            自定義::儲存Instance整數(key = "map_y", value = "{instance.map_y}+1");
        } else if((direction == "上")) {
            自定義::儲存Instance整數(key = "map_y", value = "{instance.map_y}-1");
        }
        移動角色位置(actorId = "instance", x = 23, y = 23);
    }
}
def 地圖::移動進入泛型(direction) : block {
    __repeat__ = -1;
    __label__ = "地圖";
    checks {
        找出所有角色(actor = 角色::任何玩家, varname = "instance");
        角色所在區域(actorId = "instance", region_h = 1, region_w = 1, region_x = 23, region_y = 23);
        比較數字(lhs = "{map_used_{instance.map_x}_{instance.map_y}}", op = "==", rhs = "1");
        比對字串(str = direction, value = "{instance.map_direction}");
    }
    actions {
        if((direction == "右")) {
            移動角色位置(actorId = "instance", x = "{chunk_{map_to_chunk_{instance.map_x}_{instance.map_y}}_x}", y = "{chunk_{map_to_chunk_{instance.map_x}_{instance.map_y}}_y} + {instance.tmp_grid_y_offset}");
        } else if((direction == "左")) {
            移動角色位置(actorId = "instance", x = "{chunk_{map_to_chunk_{instance.map_x}_{instance.map_y}}_x} + 19", y = "{chunk_{map_to_chunk_{instance.map_x}_{instance.map_y}}_y} + {instance.tmp_grid_y_offset}");
        } else if((direction == "下")) {
            移動角色位置(actorId = "instance", x = "{chunk_{map_to_chunk_{instance.map_x}_{instance.map_y}}_x} + {instance.tmp_grid_x_offset}", y = "{chunk_{map_to_chunk_{instance.map_x}_{instance.map_y}}_y}");
        } else if((direction == "上")) {
            移動角色位置(actorId = "instance", x = "{chunk_{map_to_chunk_{instance.map_x}_{instance.map_y}}_x} + {instance.tmp_grid_x_offset}", y = "{chunk_{map_to_chunk_{instance.map_x}_{instance.map_y}}_y} + 19");
        }
        等待(duration = 1000);
        儲存全域變數(key = "chunk_entering_{map_to_chunk_{instance.map_x}_{instance.map_y}}", type = "int", value = 0);
    }
}
def 地圖::移動移除物件泛型(chunk_id) : block {
    __repeat__ = -1;
    __label__ = "地圖";
    checks {
        計算人數(actor = 角色::任何玩家, op = "==", value = 0, region_h = 20, region_w = 20, region_x = ((chunk_id % 3) * 27), region_y = ((chunk_id / 3) * 27));
        比較數字(lhs = ("{chunk_entering_" + (twge::to_string(chunk_id) + "}")), op = "==", rhs = 0);
        比較數字(lhs = ("{chunk_used_" + (twge::to_string(chunk_id) + "}")), op = "==", rhs = 1);
    }
    actions {
        移除地圖機關(region_h = 20, region_w = 20, region_x = ((chunk_id % 3) * 27), region_y = ((chunk_id / 3) * 27));
        移除地圖物件(region_h = 20, region_w = 20, region_x = ((chunk_id % 3) * 27), region_y = ((chunk_id / 3) * 27));
        儲存全域變數(key = ("chunk_used_" + twge::to_string(chunk_id)), type = "int", value = 0);
        儲存全域變數(key = "map_tmp_to_release_x", type = "int", value = ("{chunk_to_map_" + (twge::to_string(chunk_id) + "_x}")));
        儲存全域變數(key = "map_tmp_to_release_y", type = "int", value = ("{chunk_to_map_" + (twge::to_string(chunk_id) + "_y}")));
        儲存全域變數(key = "map_used_{map_tmp_to_release_x}_{map_tmp_to_release_y}", type = "int", value = 0);
        儲存全域變數(key = "map_to_chunk_{map_tmp_to_release_x}_{map_tmp_to_release_y}", type = "int", value = -1);
        儲存全域變數(key = "chunk_available_stack_8", type = "int", value = chunk_id);
    }
}
def 地圖::移動移除人物泛型(chunk_id) : block {
    __repeat__ = -1;
    __label__ = "地圖";
    checks {
        比較數字(lhs = ("{chunk_used_" + (twge::to_string(chunk_id) + "}")), op = "==", rhs = 0);
        找出所有角色(actor = 角色::任何電腦, varname = "instance");
        角色所在區域(actorId = "instance", region_h = 20, region_w = 20, region_x = ((chunk_id % 3) * 27), region_y = ((chunk_id / 3) * 27), checkAlive = true);
    }
    actions {
        角色消失(actorId = "instance");
    }
}
def 面板::顯示能力面板() : actions {
    彈出選項視窗(actorId = "{instance}", dialogId = "dialog_point", message = 面板::能力頁, options = [Button(id = "dialog_button_point_STR_01", text = "分配一點力量"),Button(id = "dialog_button_point_STR_10", text = "分配十點力量"),Button(id = "dialog_button_point_CON_01", text = "分配一點體質"),Button(id = "dialog_button_point_CON_10", text = "分配十點體質"),Button(id = "dialog_button_point_AGI_01", text = "分配一點敏捷"),Button(id = "dialog_button_point_AGI_10", text = "分配十點敏捷"),Button(id = "dialog_button_point_INT_01", text = "分配一點智慧"),Button(id = "dialog_button_point_INT_10", text = "分配十點智慧"),Button(id = "dialog_button_point_PSY_01", text = "分配一點精神"),Button(id = "dialog_button_point_PSY_10", text = "分配十點精神")]);
}
def 面板::點擊能力分配泛型(type, typeZh, value) : block {
    __repeat__ = -1;
    __label__ = "面板";
    triggers {
        視窗確認(buttonName = ("dialog_button_point_" + (type + ("_" + value))), playerLocalId = "instance");
    }
    checks {
        比較數字(lhs = "{instance.Point}", op = ">=", rhs = value);
    }
    actions {
        關閉彈出視窗(actorId = "{instance}", dialogId = "dialog_point");
        自定義::儲存Instance整數(key = "Point", value = ("{instance.Point} - " + value));
        自定義::儲存Instance整數(key = type, value = ("{instance." + (type + ("} + " + value))));
        自定義::更新角色屬性(actorId = "instance");
        自定義::上載Instance數據();
        面板::顯示能力面板();
    }
}
block 下載老玩家數據 {
    __repeat__ = -1;
    __label__ = "玩家";
    checks {
        找出所有角色(actor = 角色::任何玩家, varname = "instance");
        比較數字(lhs = "{instance.completedInit}", op = "==", rhs = 1);
        if(true) {
            比對字串(str = "{{instance}_savedBefore}", matchKind = "equal", value = "1");
        } else {
            比對字串(str = "{{instance}_savedBefore}", matchKind = "equal", value = "undefined");
        }
    }
    actions {
        儲存物件變數(key = "completedInit", object = "instance", type = "string", value = 2);
        if(true) {
            自定義::輔助::下載Instance數據(key = "Point");
            自定義::輔助::下載Instance數據(key = "ExpNeeded");
            自定義::輔助::下載Instance數據(key = "Level");
            自定義::輔助::下載Instance數據(key = "STR");
            自定義::輔助::下載Instance數據(key = "CON");
            自定義::輔助::下載Instance數據(key = "AGI");
            自定義::輔助::下載Instance數據(key = "INT");
            自定義::輔助::下載Instance數據(key = "PSY");
            自定義::輔助::下載Instance數據(key = "Exp");
            自定義::輔助::下載Instance數據(key = "HP");
            自定義::更新角色屬性(actorId = "instance");
            角色加減血(actorCode = "instance", type = "heal", value = 9999);
        }
        角色說話(actorId = "instance", cleanTalk = true, text = "初始化完畢");
    }
}
