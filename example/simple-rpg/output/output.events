{
    "$schema": "https://code.gamelet.com/gassets/schema/events/v1",
    "config": {
        "stage": {
            "width": 600,
            "height": 500,
            "backgroundColor": "#999999",
            "resolutionPolicy": "showAll",
            "alignHorizontal": "center",
            "alignVertical": "middle"
        },
        "preload": {
            "sources": [],
            "resourcesExclude": []
        },
        "configs": {
            "TwilightWarsConfig": {
                "title": "RPG試驗",
                "serverConfig": {
                    "minPlayers": 1,
                    "supportSignin": true,
                    "mustLogin": true,
                    "allowGuest": true,
                    "supportMsgServer": true,
                    "gamezoneCode": "mission",
                    "roomType": "close",
                    "roomSize": 8
                },
                "runGame": true,
                "gameStartFadein": "fadein",
                "lives": 9999,
                "debugCamp": "ask",
                "releaseCamp": "ask",
                "setInitFocus": false,
                "initFocus": {
                    "x": "0",
                    "y": "0"
                },
                "campOptions": {
                    "campOpSkydow": true,
                    "campOpRoyal": true,
                    "campOpThird": true
                },
                "map": "CG.TWilightGameEventCompiler/rpg/simple_rpg.twmap",
                "maxAbilityLevel": 2,
                "nextGameEnabled": true,
                "disableNextGameOnMissionComplete": false,
                "playDefaultMusic": true,
                "cameraAfterOver": "restrict",
                "useDefaultItems": true,
                "useDefaultCampLocs": false,
                "skydowLocs": [
                    {
                        "x": "10",
                        "y": "10"
                    }
                ],
                "royalLocs": [
                    {
                        "x": "10",
                        "y": "10"
                    }
                ],
                "thirdLocs": [
                    {
                        "x": "10",
                        "y": "10"
                    }
                ],
                "useCustomWeapons": true,
                "customWeapons": [
                    {
                        "code": "wind_staff",
                        "config": {
                                "type": "close",
                                "clipAlias": "TWilightGameEventCompiler.weapon_wind_staff",
                                "scaleOnGround": 0.8,
                                "scaleOnIcon": 1,
                                "pickTestFunc": "wider",
                                "weight": 6,
                                "damage": 0,
                                "swapTime": 800,
                                "frameName": "BLADE_TYPE",
                                "clip": "",
                                "fireTime": 1500,
                                "fires": [
                                    {
                                        "fireType": "backslash",
                                        "deltaDamage": 0
                                    }
                                ],
                                "sprite": {
                                    "pivotOnHand": {
                                        "x": 2,
                                        "y": 9,
                                        "degrees": 58,
                                        "scale": {
                                            "x": 1.3,
                                            "y": 1.5
                                        }
                                    },
                                    "pivotOnIcon": {
                                        "x": 20,
                                        "y": 20,
                                        "degrees": -40,
                                        "scale": {
                                            "x": 1,
                                            "y": 1
                                        }
                                    }
                                }
                            }
                    },
                    {
                        "code": "iron_sword",
                        "config": {
                                "type": "close",
                                "clipAlias": "TWilightGameEventCompiler.weapon_iron_sword",
                                "scaleOnGround": 0.8,
                                "scaleOnIcon": 1,
                                "pickTestFunc": "wider",
                                "weight": 6,
                                "damage": 0,
                                "swapTime": 800,
                                "frameName": "BLADE_TYPE",
                                "clip": "",
                                "fireTime": 1500,
                                "fires": [
                                    {
                                        "fireType": "sword",
                                        "deltaDamage": 0
                                    }
                                ],
                                "sprite": {
                                    "pivotOnHand": {
                                        "x": -12,
                                        "y": 0,
                                        "degrees": 35,
                                        "scale": {
                                            "x": 1,
                                            "y": 1
                                        }
                                    },
                                    "pivotOnIcon": {
                                        "x": 27,
                                        "y": 14,
                                        "degrees": -40,
                                        "scale": {
                                            "x": 1,
                                            "y": 1
                                        }
                                    }
                                }
                            }
                    },
                    {
                        "code": "dagger",
                        "config": {
                                "type": "close",
                                "clipAlias": "TWilightGameEventCompiler.weapon_dagger",
                                "scaleOnGround": 0.8,
                                "scaleOnIcon": 1,
                                "pickTestFunc": "wider",
                                "weight": 3,
                                "damage": 0,
                                "swapTime": 800,
                                "frameName": "BLADE_TYPE",
                                "clip": "",
                                "fireTime": 1500,
                                "fires": [
                                    {
                                        "fireType": "knife",
                                        "deltaDamage": 0
                                    }
                                ],
                                "sprite": {
                                    "pivotOnHand": {
                                        "x": 34,
                                        "y": 24,
                                        "degrees": -92,
                                        "scale": {
                                            "x": 0.7,
                                            "y": 0.8
                                        }
                                    },
                                    "pivotOnIcon": {
                                        "x": 34,
                                        "y": 16,
                                        "degrees": -140,
                                        "scale": {
                                            "x": 1,
                                            "y": 1
                                        }
                                    }
                                }
                            }
                    }
                ],
                "useCustomItems": false,
                "customItems": [],
                "enabled": true,
                "@use": 0
            }
        }
    },
    "events": [
        {
            "id": "下載老玩家數據",
            "disabled": false,
            "folder": "玩家",
            "startTime": 0,
            "checkInterval": 10,
            "repeats": -1,
            "repeatInterval": 0,
            "devOnly": false,
            "actions": [
                {
                    "type": "SetObjectVar",
                    "data": {
                        "objectId": "instance",
                        "key": "completedInit",
                        "valueType": "string",
                        "value": "2"
                    }
                },
                {
                    "type": "GetUserState",
                    "data": {
                        "playerId": "{instance}",
                        "category": "simple-rpg-test",
                        "key": "Point",
                        "varname": "{instance}_Point"
                    }
                },
                {
                    "type": "SetObjectVar",
                    "data": {
                        "objectId": "instance",
                        "key": "Point",
                        "valueType": "integer",
                        "value": "{{instance}_Point}"
                    }
                },
                {
                    "type": "GetUserState",
                    "data": {
                        "playerId": "{instance}",
                        "category": "simple-rpg-test",
                        "key": "ExpNeeded",
