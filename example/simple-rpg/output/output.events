                    }
                },
                {
                    "type": "SetObjectVar",
                    "data": {
                        "objectId": "instance",
                        "key": "ExpNeeded",
                        "valueType": "integer",
                        "value": "{{instance}_ExpNeeded}"
                    }
                },
                {
                    "type": "GetUserState",
