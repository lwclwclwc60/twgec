                    }
                },
                {
                    "type": "GetUserState",
                    "data": {
                        "playerId": "{instance}",
                        "category": "simple-rpg-test",
                        "key": "Exp",
                        "varname": "{instance}_Exp"
                    }
                },
                {
                    "type": "SetObjectVar",
                    "data": {
                        "objectId": "instance",
                        "key": "Exp",
                        "valueType": "integer",
                        "value": "{{instance}_Exp}"
                    }
                },
                {
                    "type": "GetUserState",
                    "data": {
                        "playerId": "{instance}",
                        "category": "simple-rpg-test",
                        "key": "HP",
                        "varname": "{instance}_HP"
                    }
                },
                {
                    "type": "SetObjectVar",
                    "data": {
                        "objectId": "instance",
                        "key": "HP",
                        "valueType": "integer",
                        "value": "{{instance}_HP}"
                    }
                },
                {
                    "type": "SetObjectVar",
                    "data": {
                        "objectId": "instance",
                        "key": "HP",
                        "valueType": "integer",
                        "value": "98 + 10*{instance.CON} + 2*{instance.Level}"
                    }
                },
                {
                    "type": "ActorAttributes",
                    "data": {
                        "actorCode": "instance",
                        "ops": [
                            {
                                "attr": "maxHp",
                                "operation": "set",
                                "value": "{instance.HP}"
                            }
                        ],
                        "takeFriendAIFire": "u",
                        "takeFriendPlayerFire": "u",
                        "exitWormhole": "u",
                        "setStatic": "u",
                        "setTornadoRes": "u",
                        "bloodType": "u"
                    }
                },
                {
                    "type": "ActorAttributes",
                    "data": {
                        "actorCode": "instance",
                        "ops": [
                            {
                                "attr": "closeWeaponSpeed",
                                "operation": "set",
                                "value": "4-3/(1+0.01*{instance.AGI})"
                            }
                        ],
                        "takeFriendAIFire": "u",
                        "takeFriendPlayerFire": "u",
                        "exitWormhole": "u",
                        "setStatic": "u",
                        "setTornadoRes": "u",
                        "bloodType": "u"
                    }
                },
                {
                    "type": "ActorAttributes",
                    "data": {
                        "actorCode": "instance",
                        "ops": [
                            {
                                "attr": "weight",
                                "operation": "set",
                                "value": "3*pow(0.97,{instance.AGI})"
                            }
                        ],
                        "takeFriendAIFire": "u",
                        "takeFriendPlayerFire": "u",
                        "exitWormhole": "u",
                        "setStatic": "u",
                        "setTornadoRes": "u",
                        "bloodType": "u"
                    }
                },
                {
                    "type": "DeltaHp",
                    "data": {
                        "actorCode": "instance",
                        "deltaType": "heal",
                        "hp": "9999",
                        "casterCode": ""
                    }
                },
                {
                    "type": "ActorTalk",
                    "data": {
                        "cleanTalk": true,
                        "speech": "初始化完畢",
                        "duration": "3000",
                        "wait": false,
                        "waitMore": "100",
                        "actorCode": "instance"
                    }
                }
            ],
            "checks": [
                {
                    "type": "ForEachActor",
                    "data": {
                        "actorMatches": [
                            {
                                "actorCodes": [
                                    {
                                        "method": "contain",
                                        "actorCode": ""
                                    }
                                ],
                                "brain": "player",
                                "camp": {
                                    "campAll": true
                                },
                                "excludeActorCodes": []
                            }
                        ],
                        "varname": "instance",
                        "maxTriggers": "0",
                        "donotActOnEachPass": false,
                        "varnameTotalLoops": "totalLoops",
                        "varnameOfPassCount": "totalPasses",
                        "_logi": {
                            "_and_or": ""
                        },
                        "_elseEventId": ""
                    }
                },
                {
                    "type": "NumberCheck",
                    "data": {
                        "value1": "{instance.completedInit}",
                        "operator": "==",
                        "value2": "1",
                        "_logi": {
                            "_and_or": ""
                        },
                        "_elseEventId": ""
                    }
                },
                {
                    "type": "String",
                    "data": {
                        "value": "1",
                        "method": "equal",
                        "str": "{{instance}_savedBefore}",
                        "eventLocal": "",
                        "_logi": {
                            "_and_or": ""
                        },
                        "_elseEventId": ""
                    }
                }
            ],
            "triggers": []
        },
