def 地圖::新增能力點告示牌(x, y, text, type) : actions {
    新增地圖物件(x = x, y = y, object = "石椅");
    新增告示牌(x = x, y = y, rotation = 180, text = text, buttons = [
        Button(id = "increase" + type + "1", text = "提升一點"),
        Button(id = "increase" + type + "10", text = "提升十點")
    ]);
}

def 地圖::生成地圖配置(x, y, object) : actions {
    // '---' 用作padding
    if(object == "---" || object == " . ") {}
    // 生成木板 SP - Point, SW - Weapon, SS - Skill
    else if(object == "SP0") {
        新增地圖物件(x = x, y = y, object = "石椅");
        新增告示牌(x = x, y = y, rotation = 180, text = "【重置能力點分配】", buttons = [Button(id = "ResetPoint", text = "確認")]);
    } else if(object == "SP1") {
        地圖::新增能力點告示牌(x, y, 文字::力量描述, "STR");
    } else if(object == "SP2") {
        地圖::新增能力點告示牌(x, y, 文字::體質描述, "CON");
    } else if(object == "SP3") {
        地圖::新增能力點告示牌(x, y, 文字::敏捷描述, "AGI");
    } else if(object == "SP4") {
        地圖::新增能力點告示牌(x, y, 文字::智慧描述, "INT");
    } else if(object == "SP5") {
        地圖::新增能力點告示牌(x, y, 文字::精神描述, "PSY");
    } else if(object == "SW1") {
        新增地圖物件(x = x, y = y, object = "小箱子");
        新增告示牌(x = x, y = y, rotation = 90, text = 文字::風杖描述, buttons = [Button(id = "wearWindStaff", text = "裝備"), Button(id = "wearNone", text = "卸下")]);
    } else if(object == "SW2") {
        新增地圖物件(x = x, y = y, object = "小箱子");
        新增告示牌(x = 5, y = 7, rotation = 90, text = 文字::匕首描述, buttons = [Button(id = "wearDagger", text = "裝備"), Button(id = "wearNone", text = "卸下")]);
    } else if(object == "SW3") {
        新增地圖物件(x = x, y = y, object = "小箱子");
        新增告示牌(x = 6, y = 7, rotation = 90, text = 文字::鐵劍描述, buttons = [Button(id = "wearIronSword", text = "裝備"), Button(id = "wearNone", text = "卸下")]);
    } else if(object == "SS1") {
        新增地圖物件(x = x, y = y, object = "小箱子");
        新增告示牌(x = x, y = y, rotation = 180, text = 文字::火星領域描述, buttons = [
            Button(id = "setX" + 別名::技能火星領域EN, text = "設置於X鍵"), 
            Button(id = "setXNone", text = "卸下")]);
    } else if(object == "SS2") {
        新增地圖物件(x = x, y = y, object = "小箱子");
        新增告示牌(x = x, y = y, rotation = 180, text = 文字::震撼描述, buttons = [
            Button(id = "setX" + 別名::技能震撼EN, text = "設置於X鍵"), 
            Button(id = "setXNone", text = "卸下")]);
    } else if(object == "SS3") {
        新增地圖物件(x = x, y = y, object = "小箱子");
        新增告示牌(x = x, y = y, rotation = 180, text = 文字::土靈召喚, buttons = [
            Button(id = "setX" + 別名::技能土靈召喚EN, text = "設置於X鍵"), 
            Button(id = "setXNone", text = "卸下")]);
    }
    // 生成NPC
    else if(object == "NP1") {
        新增角色(name = "武器商人", id = "npc01*", camp = "第三", x = x, y = y, rotation = 90,
                weapon1 = "fist", weapon2 = "fist", teamId = 100, role = "隱居士");
    } else if(object == "NP2") {
        新增角色(name = "技能商人", id = "npc02*", camp = "第三", x = x, y = y, rotation = 180,
                weapon1 = "fist", weapon2 = "fist", teamId = 100, role = "赤焰精靈");
    }
    // 生成地圖物件
    else if(object == "LBx") {
        新增地圖物件(x = x, y = y, object = "大箱子", walkable = false);
    } else if(object == "SBx") {
        新增地圖物件(x = x, y = y, object = "小箱子", walkable = false);
    } else if(object == "H00") {
        新增地圖物件(x = x, y = y, object = "5x4橫向房子", walkable = false);
    } else if(object == "H01") {
        新增地圖物件(x = x, y = y, object = "5x4縱向房子", walkable = false);
    } else if(object == "***") {
        新增地圖物件(x = x, y = y, object = "草地");
    } else if(object == "t00") {
        新增地圖物件(x = x, y = y, object = "3x3綠樹");
    // 生成出口
    } else if(object == "ExN") {
        新增地圖物件(x = x, y = y, object = "白光(上)");
    } else if(object == "ExE") {
        新增地圖物件(x = x, y = y, object = "白光(右)");
    } else if(object == "ExS") {
        新增地圖物件(x = x, y = y, object = "白光(下)");
    } else if(object == "ExW") {
        新增地圖物件(x = x, y = y, object = "白光(左)");
    } else {
        // TODO: support twge::assert(bool, string)
        print(text = "無效Object:" + object, type = "error");
    }
}

def 地圖::生成地圖(xOffset, yOffset, mapArray) : actions {
    print(text = "xOffset:" + xOffset);
    print(text = "yOffset:" + yOffset);
    for(map_row in 0...(twge::get_length(mapArray) - 1)) {
        for(map_col in 0...(twge::get_length(twge::get_index(mapArray, map_row))/3 - 1)) {
            地圖::生成地圖配置(
                twge::to_string(map_col) + "+" + xOffset, twge::to_string(map_row) + "+" + yOffset,
                twge::get_slice(twge::get_index(mapArray, map_row), map_col*3 + 0, map_col*3 + 2)
            );
        }
    }
}

def 地圖::儲存地圖變量(x, y, map) : actions {
    if(twge::get_slice(twge::get_index(map,0),27,32) == "ExNExN") {
        儲存全域變數(key = "map_" + twge::to_string(x) + "_" + twge::to_string(y) + "_ExN", type = "int", value = 1);
    }
    if(twge::get_slice(twge::get_index(map,19),27,32) == "ExSExS"){
        儲存全域變數(key = "map_" + twge::to_string(x) + "_" + twge::to_string(y) + "_ExS", type = "int", value = 1);
    }
    if(twge::get_slice(twge::get_index(map,9),0,2) == "ExW" &&
       twge::get_slice(twge::get_index(map,10),0,2) == "ExW") {
        儲存全域變數(key = "map_" + twge::to_string(x) + "_" + twge::to_string(y) + "_ExW", type = "int", value = 1);
    }
    if(twge::get_slice(twge::get_index(map,9),57,59) == "ExE" &&
       twge::get_slice(twge::get_index(map,10),57,59) == "ExE") {
        儲存全域變數(key = "map_" + twge::to_string(x) + "_" + twge::to_string(y) + "_ExE", type = "int", value = 1);
    }
    儲存全域變數(key = "map_used_" + twge::to_string(x) + "_" + twge::to_string(y), type = "int", value = 0);
}

def 自定義::設定雙向地圖傳送點(x1, y1, x2, y2): actions {
    if (x1 == x2 && y1 < y2) {
        設定地圖傳送點(fromX = x1, fromY = y1, toX = x2, toY = y2, direction = "下");
        設定地圖傳送點(fromX = x2, fromY = y2, toX = x1, toY = y1, direction = "上");
    } else if (x1 == x2 && y1 > y2) {
        設定地圖傳送點(fromX = x1, fromY = y1, toX = x2, toY = y2, direction = "上");
        設定地圖傳送點(fromX = x2, fromY = y2, toX = x1, toY = y1, direction = "下");
    } else if (x1 > x2 && y1 == y2) {
        設定地圖傳送點(fromX = x1, fromY = y1, toX = x2, toY = y2, direction = "左");
        設定地圖傳送點(fromX = x2, fromY = y2, toX = x1, toY = y1, direction = "右");
    } else if (x1 < x2 && y1 == y2) {
        設定地圖傳送點(fromX = x1, fromY = y1, toX = x2, toY = y2, direction = "右");
        設定地圖傳送點(fromX = x2, fromY = y2, toX = x1, toY = y1, direction = "左");
    } else if (x1 == x2 && y1 == y2) {
        print(type = "error", text = "Cannot set the same point as the mapWarp src and dst");
    } else {
        print(type = "error", text = "Bidirectional mapWarp requires x or y to be the same value");
    }
}

def 地圖::移動離開泛型(direction) : block {
    __repeat__ = -1;
    __label__ = "地圖";
    triggers {
        鍵盤按鍵(varName = "clicker", key = "Space");
    }
    checks {
        // 864 = 27*32 where 27 is the stride and 32 is the pixel size
        if(direction == "右") {
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = ">=", rhs = "19*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = "<=", rhs = "20*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = ">=", rhs = "9*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = "<=", rhs = "11*32");
            比較數字(lhs = "{map_{{clicker.id}.map_x}_{{clicker.id}.map_y}_ExE}", op = "==", rhs = 1);
        } else if(direction == "左") {
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = ">=", rhs = "0*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = "<=", rhs = "1*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = ">=", rhs = "9*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = "<=", rhs = "11*32");
            比較數字(lhs = "{map_{{clicker.id}.map_x}_{{clicker.id}.map_y}_ExW}", op = "==", rhs = 1);
        } else if(direction == "下") {
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = ">=", rhs = "19*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = "<=", rhs = "20*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = ">=", rhs = "9*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = "<=", rhs = "11*32");
            比較數字(lhs = "{map_{{clicker.id}.map_x}_{{clicker.id}.map_y}_ExS}", op = "==", rhs = 1);
        } else if(direction == "上") {
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = ">=", rhs = "0*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.y} % 864", op = "<=", rhs = "1*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = ">=", rhs = "9*32");
            比較數字(lhs = "{{clicker.id}.gamePosition.x} % 864", op = "<=", rhs = "11*32");
            比較數字(lhs = "{map_{{clicker.id}.map_x}_{{clicker.id}.map_y}_ExN}", op = "==", rhs = 1);
        }
    }
    actions {
        setGlobal(key = "instance", type = "string", value = "{clicker.id}");
        自定義::儲存Instance整數("tmp_grid_x_offset", "({instance.gamePosition.x}%864)/32");
        自定義::儲存Instance整數("tmp_grid_y_offset", "({instance.gamePosition.y}%864)/32");
        if(除錯模式) {
            print(text = "x: {instance.map_x}, y: {instance.map_y}, direction: " + direction, type = "error");
            print(text = "x_offset: {instance.tmp_grid_x_offset}, y_offset: {instance.tmp_grid_x_offset}", type = "error");
        }
        儲存物件變數(key = "map_direction", object = "instance", type = "string", value = direction);
        if(direction == "右") {
            自定義::儲存Instance整數("map_x", "{instance.map_x}+1");
        } else if(direction == "左") {
            自定義::儲存Instance整數("map_x", "{instance.map_x}-1");
        } else if(direction == "下") {
            自定義::儲存Instance整數("map_y", "{instance.map_y}+1");
        } else if(direction == "上") {
            自定義::儲存Instance整數("map_y", "{instance.map_y}-1");
        }
        移動角色位置(actorId = "instance", x = 23, y = 23);
    }
}

