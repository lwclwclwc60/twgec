def 地圖::移動生成泛型(map_x, map_y) : block {
    __repeat__ = -1;
    __label__ = "地圖";
    checks {
        找出所有角色(actor = 角色::任何玩家, varname = "instance");
        角色所在區域(actorId = "instance", region_h = 1, region_w = 1, region_x = 23, region_y = 23);
        比較數字(lhs = "{map_used_{instance.map_x}_{instance.map_y}}", op = "==", rhs = "0");
        比較數字(lhs = "{instance.map_x}", op = "==", rhs = map_x);
        比較數字(lhs = "{instance.map_y}", op = "==", rhs = map_y);
        比較數字(lhs = "{chunk_available_stack_0}", op = "!=", rhs = -1);
        比較數字(lhs = "{chunk_available_stack_now}", op = "==", rhs = -1);
    }
    actions {
        儲存全域變數(key = "chunk_available_stack_now", type = "int", value = "{chunk_available_stack_0}");
        儲存全域變數(key = "chunk_available_stack_0", type = "int", value = "{chunk_available_stack_1}");
        儲存全域變數(key = "chunk_available_stack_1", type = "int", value = "{chunk_available_stack_2}");
        儲存全域變數(key = "chunk_available_stack_2", type = "int", value = "{chunk_available_stack_3}");
        儲存全域變數(key = "chunk_available_stack_3", type = "int", value = "{chunk_available_stack_4}");
        儲存全域變數(key = "chunk_available_stack_4", type = "int", value = "{chunk_available_stack_5}");
        儲存全域變數(key = "chunk_available_stack_5", type = "int", value = "{chunk_available_stack_6}");
        儲存全域變數(key = "chunk_available_stack_6", type = "int", value = "{chunk_available_stack_7}");
        儲存全域變數(key = "chunk_available_stack_7", type = "int", value = "{chunk_available_stack_8}");
        儲存全域變數(key = "chunk_available_stack_8", type = "int", value = -1);
        儲存全域變數(key = "map_to_chunk_{instance.map_x}_{instance.map_y}", type = "int", value = "{chunk_available_stack_now}");
        if(map_x == 99 && map_y == 100) {
            地圖::生成地圖("{chunk_{chunk_available_stack_now}_x}", "{chunk_{chunk_available_stack_now}_y}", 地圖::新手村近郊99n100);
        } else if(map_x == 101 && map_y == 100) {
            地圖::生成地圖("{chunk_{chunk_available_stack_now}_x}", "{chunk_{chunk_available_stack_now}_y}", 地圖::新手村近郊101n100);
        } else if(map_x == 99 && map_y == 101) {
            地圖::生成地圖("{chunk_{chunk_available_stack_now}_x}", "{chunk_{chunk_available_stack_now}_y}", 地圖::新手村近郊99n101);
        } else if(map_x == 100 && map_y == 101) {
            地圖::生成地圖("{chunk_{chunk_available_stack_now}_x}", "{chunk_{chunk_available_stack_now}_y}",  地圖::新手村近郊100n101);
        } else if(map_x == 101 && map_y == 101) {
            地圖::生成地圖("{chunk_{chunk_available_stack_now}_x}", "{chunk_{chunk_available_stack_now}_y}",  地圖::新手村近郊101n101);
        }
        儲存全域變數(key = "chunk_to_map_{chunk_available_stack_now}_x", type = "int", value = "{instance.map_x}");
        儲存全域變數(key = "chunk_to_map_{chunk_available_stack_now}_y", type = "int", value = "{instance.map_y}");
        儲存全域變數(key = "map_used_{instance.map_x}_{instance.map_y}", type = "int", value = 1);
        儲存全域變數(key = "chunk_used_{chunk_available_stack_now}", type = "int", value = 1);
        儲存全域變數(key = "chunk_available_stack_now", type = "int", value = -1);
    }
}

