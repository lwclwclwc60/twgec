def 地圖::移動進入泛型(direction) : block {
    __repeat__ = -1;
    __label__ = "地圖";
    checks {
        找出所有角色(actor = 角色::任何玩家, varname = "instance");
        角色所在區域(actorId = "instance", region_h = 1, region_w = 1, region_x = 23, region_y = 23);
        比較數字(lhs = "{map_used_{instance.map_x}_{instance.map_y}}", op = "==", rhs = "1");
        比對字串(str = direction, value = "{instance.map_direction}");
    }
    actions {
        if(direction == "右") {
            移動角色位置(actorId = "instance",
                x = "{chunk_{map_to_chunk_{instance.map_x}_{instance.map_y}}_x}",
                y = "{chunk_{map_to_chunk_{instance.map_x}_{instance.map_y}}_y} + {instance.tmp_grid_y_offset}");
        } else if(direction == "左") {
            移動角色位置(actorId = "instance",
                x = "{chunk_{map_to_chunk_{instance.map_x}_{instance.map_y}}_x} + 19",
                y = "{chunk_{map_to_chunk_{instance.map_x}_{instance.map_y}}_y} + {instance.tmp_grid_y_offset}");
        } else if(direction == "下") {
            移動角色位置(actorId = "instance",
                x = "{chunk_{map_to_chunk_{instance.map_x}_{instance.map_y}}_x} + {instance.tmp_grid_x_offset}",
                y = "{chunk_{map_to_chunk_{instance.map_x}_{instance.map_y}}_y}");
        } else if(direction == "上") {
            移動角色位置(actorId = "instance",
                x = "{chunk_{map_to_chunk_{instance.map_x}_{instance.map_y}}_x} + {instance.tmp_grid_x_offset}",
                y = "{chunk_{map_to_chunk_{instance.map_x}_{instance.map_y}}_y} + 19");
        }
    }
}
