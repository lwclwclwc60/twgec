// TODO: Support syntax
// def 自定義::野獸重生拳頭類泛型(actor_id, name, x, y, range, hp, strength, role) : block = 
//      野獸重生拳頭類泛型(actor_id, name, x, y, range, hp, "fist", "fist", strength, role);
// TODO: Support typing
def 自定義::野獸重生泛型(interval, chunk_x, chunk_y, monster_type, level) : block {
    __repeat__ = -1;
    __repeatInterval__ = interval;
    __delay__ = 1000;
    __label__ = "怪物";
    checks {
        if(monster_type == "鹿") {
            if(chunk_x == "101" && chunk_y == "102") {
                計算人數(actor = ActorMatch(id = "monster_deer_lv0" + twge::to_string(level), matchKind = "contain"), op = "<", value = 2);
            } else {
                計算人數(actor = ActorMatch(id = "monster_deer_lv0" + twge::to_string(level), matchKind = "contain"), op = "<", value = 4);
            }
        }
        if(monster_type == "山嶺石怪") {
            計算人數(actor = ActorMatch(id = "monster_stone_lv0" + twge::to_string(level), matchKind = "contain"), op = "<", value = 1);
        }
        比較數字(lhs = "{map_used_" + chunk_x +"_" + chunk_y + "}", op = "==", rhs = "1");
    }
    actions {
        if(monster_type == "鹿") {
            新增角色(name = monster_type + "(Lv" + twge::to_string(level) + ")",
                    id = "monster_deer_lv0" + twge::to_string(level) + "*",
                    hp = 15 + 45 * level,
                    strength = 5 + 5 * level,
                    x = "{chunk_{map_to_chunk_" + chunk_x + "_" + chunk_y + "}_x} + 10",
                    y = "{chunk_{map_to_chunk_" + chunk_x + "_" + chunk_y + "}_y} + 10", 
                    camp = "第三", range = 10, localVarname = "actor",
                    weapon1 = "fist", weapon2 = "fist", teamId = 101, role = "鹿");
        }
        if(monster_type == "山嶺石怪") {
            新增角色(name = monster_type + "(Lv" + twge::to_string(level) + ")",
                    id = "monster_stone_lv0" + twge::to_string(level) + "*",
                    hp = 20 + 80 * level,
                    strength = 10 * level,
                    x = "{chunk_{map_to_chunk_" + chunk_x + "_" + chunk_y + "}_x} + 10",
                    y = "{chunk_{map_to_chunk_" + chunk_x + "_" + chunk_y + "}_y} + 10", 
                    camp = "第三", range = 10, localVarname = "actor",
                    weapon1 = "fist", weapon2 = "fist", teamId = 101, role = "石怪");
            設定角色屬性(actorId = "{actor}", attr = "體重", value = "6");
            設定角色屬性(actorId = "{actor}", attr = "體型縮放", value = "1.1");
        }
        跟隨人物(actorId = "actor", type = "跟隨自己");
    }
}

